---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700&family=Fira+Code:wght@400&display=swap" rel="stylesheet">

<Layout title="Home">
<style>
  :root {
    --bg-app: #1e1e1e;
    --bg-sidebar: #181818;
    --bg-titlebar: #323233;
    --bg-tab: #2d2d2d;
    --bg-editor: #1e1e1e;
    --bg-hover: #2a2d2e;
    --bg-active: #094771;
    --bg-line-hl: #2d2d2d;
    --border: #3c3c3c;
    --border-tab: #252526;
    --border-active: #007acc;
    --pink: #ff6188;
    --orange: #ffb443;
    --yellow: #ffd47a;
    --green: #a9dc76;
    --cyan: #78dce8;
    --purple: #ab9df2;
    --blue: #7aa2f7;
    --comment: #5c6370;
    --gray: #9da5b4;
    --cat-DARK: var(--pink);
    --cat-BLOG: var(--green);
    --cat-PROJECT: var(--yellow);
    --cat-TECH: var(--cyan);
    --cat-DEVLOG: var(--orange);
    --text: #cbd0d4;
    --text-dim: #7a7a7a;
    --text-bright: #f5f5f5;
    --text-muted: #4a4a4a;
    --text-sidebar: #cccccc;
    --accent: var(--green);
  }

  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #424242; }

  .article { max-width: 100% !important; padding: 0 !important; }
  body { background: var(--bg-app) !important; }
  body::before { display: none !important; }

  .app { display: flex; flex-direction: column; height: 100vh; background: var(--bg-app); overflow: hidden; }

  /* Title Bar */
  .titlebar { display: flex; align-items: center; height: 28px; background: var(--bg-titlebar); border-bottom: 1px solid var(--border-tab); flex-shrink: 0; }
  .dots { display: flex; gap: 8px; padding: 0 12px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; cursor: pointer; }
  .dot-c { background: #ff5f56; }
  .dot-m { background: #ffbd2e; }
  .dot-x { background: #27c93f; }
  .title-txt { flex: 1; text-align: center; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-dim); }
  .title-txt .sep { color: var(--text-muted); margin: 0 6px; }
  .title-txt .fn { color: var(--gray); }
  .title-spacer { width: 76px; }

  /* Main Area */
  .main-area { display: flex; flex: 1; overflow: hidden; }

  /* Activity Bar */
  .actbar { width: 44px; background: var(--bg-sidebar); border-right: 1px solid var(--border-tab); display: flex; flex-direction: column; align-items: center; padding: 8px 0; flex-shrink: 0; }
  .actbtn { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 18px; color: var(--text-muted); cursor: pointer; background: none; border: none; transition: all 0.1s; position: relative; }
  .actbtn:hover { color: var(--gray); }
  .actbtn.on { color: var(--gray); }
  .actbtn.on::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 2px; height: 20px; background: var(--accent); }
  .actsp { flex: 1; }
  .badge { position: absolute; top: 6px; right: 6px; font-family: 'JetBrains Mono', monospace; font-size: 8px; background: var(--pink); color: white; padding: 1px 3px; line-height: 1.2; }

  /* Sidebar */
  .sidebar { width: 220px; background: var(--bg-sidebar); border-right: 1px solid var(--border); display: flex; flex-direction: column; flex-shrink: 0; overflow: hidden; }
  .shead { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px 8px; }
  .stitle { font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase; }
  .sadd { font-size: 16px; color: var(--text-muted); cursor: pointer; background: none; border: none; padding: 0; }
  .sadd:hover { color: var(--gray); }
  .tree { flex: 1; overflow-y: auto; padding-bottom: 16px; }
  .tsect { margin-bottom: 4px; }
  .thead { display: flex; align-items: center; gap: 4px; padding: 4px 12px; font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; color: var(--text-muted); letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer; }
  .thead:hover { color: var(--gray); }
  .tchev { font-size: 8px; transition: transform 0.15s; }
  .thead.open .tchev { transform: rotate(90deg); }
  .titem { display: flex; align-items: center; gap: 8px; padding: 5px 12px 5px 20px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--text-sidebar); cursor: pointer; text-decoration: none; border: none; transition: background 0.1s; }
  .titem:hover { background: var(--bg-hover); }
  .titem.on { background: var(--bg-active); color: var(--text-bright); }
  .ticon { font-size: 11px; opacity: 0.6; flex-shrink: 0; }
  .tname { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* Editor Area */
  .edarea { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--bg-editor); }
  .tabs { display: flex; background: var(--bg-tab); border-bottom: 1px solid var(--border); overflow-x: auto; flex-shrink: 0; }
  .tabs::-webkit-scrollbar { height: 2px; }
  .tab { display: flex; align-items: center; gap: 6px; padding: 7px 14px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--text-dim); border-right: 1px solid var(--border); cursor: pointer; white-space: nowrap; transition: all 0.1s; background: transparent; border-bottom: none; flex-shrink: 0; }
  .tab:hover { background: var(--bg-hover); color: var(--gray); }
  .tab.on { background: var(--bg-editor); color: var(--text-bright); border-bottom: 1px solid var(--bg-editor); margin-bottom: -1px; }
  .ti { font-size: 10px; opacity: 0.5; }
  .tn { font-size: 11px; }
  .tc { font-size: 12px; color: var(--text-muted); opacity: 0; margin-left: 4px; }
  .tab:hover .tc { opacity: 1; }
  .tc:hover { color: var(--text-bright); }

  /* Breadcrumb */
  .bc { display: flex; align-items: center; gap: 4px; padding: 0 16px; height: 22px; background: var(--bg-sidebar); border-bottom: 1px solid var(--border); font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-muted); flex-shrink: 0; }
  .ci { cursor: pointer; transition: color 0.1s; }
  .ci:hover { color: var(--gray); }
  .cs { font-size: 8px; color: var(--text-muted); }
  .ci.cur { color: var(--gray); cursor: default; }

  /* Editor Scroll */
  .edscroll { flex: 1; overflow-y: auto; overflow-x: hidden; }
  .cview { display: grid; grid-template-columns: 52px 1fr; min-height: 100%; }
  .lnums { background: var(--bg-editor); border-right: 1px solid var(--border); padding: 16px 0; position: sticky; left: 0; }
  .ln { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--text-muted); text-align: right; padding: 0 14px; line-height: 1.75; }
  .ln.on { color: var(--gray); background: var(--bg-line-hl); }
  .cbody { padding: 16px 24px 16px 20px; }

  /* File header */
  .fhdr { margin-bottom: 20px; }
  .cb { font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.8; margin-bottom: 12px; }
  .c { color: var(--comment); }
  .ck { color: var(--pink); }
  .cs2 { color: var(--yellow); }
  .cf { color: var(--cyan); }
  .cn2 { color: var(--purple); }
  .htitle { font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 700; color: var(--text-bright); letter-spacing: -0.5px; margin-bottom: 10px; }
  .htitle .kw { color: var(--cyan); }
  .htitle .fn { color: var(--green); font-weight: 400; }
  .hdesc { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--gray); line-height: 1.7; max-width: 520px; margin-bottom: 16px; }
  .cur { display: inline-block; width: 2px; height: 14px; background: var(--accent); vertical-align: middle; animation: cb 1s step-end infinite; }
  @keyframes cb { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* Meta bar */
  .mbar { display: flex; border: 1px solid var(--border); margin-bottom: 16px; }
  .mcell { flex: 1; padding: 12px 14px; border-right: 1px solid var(--border); transition: background 0.1s; display: block; text-decoration: none; }
  .mcell:last-child { border-right: none; }
  .mcell:hover { background: var(--bg-hover); }
  .mlbl { font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 700; color: var(--text-muted); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 4px; }
  .mval { font-family: 'Fira Code', monospace; font-size: 13px; color: var(--text); }
  .mval.kw { color: var(--pink); }
  .mval.live { color: var(--accent); }
  .mval.dim { color: var(--text-dim); }

  /* Imports */
  .imps { font-family: 'Fira Code', monospace; font-size: 12px; margin-bottom: 16px; border-left: 2px solid var(--border-active); padding-left: 12px; }
  .imp { color: var(--comment); margin-bottom: 4px; line-height: 1.6; }
  .imp .k { color: var(--pink); }
  .imp .p { color: var(--yellow); }
  .imp .f { color: var(--cyan); }

  /* Crypto */
  .crypto { margin-bottom: 16px; }

  /* Filter */
  .filt { display: flex; border: 1px solid var(--border); border-bottom: none; margin-bottom: 0; }
  .fb { flex: 1; font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; color: var(--text-muted); background: transparent; border: none; border-right: 1px solid var(--border); padding: 10px 12px; cursor: pointer; letter-spacing: 1px; transition: all 0.1s; }
  .fb:last-child { border-right: none; }
  .fb:hover { background: var(--bg-hover); color: var(--gray); }
  .fb.on { background: var(--bg-active); color: var(--text-bright); }

  /* Code block (posts) */
  .blk { border: 1px solid var(--border); border-top: none; margin-bottom: 16px; }
  .bhdr { display: flex; align-items: center; justify-content: space-between; padding: 6px 14px; background: var(--bg-sidebar); border-bottom: 1px solid var(--border); font-family: 'JetBrains Mono', monospace; font-size: 10px; }
  .blbl { color: var(--comment); }
  .bcnt { color: var(--text-muted); }
  .bl { display: grid; grid-template-columns: 52px 64px 1fr; font-family: 'Fira Code', monospace; font-size: 12px; line-height: 1.75; border-bottom: 1px solid var(--border); text-decoration: none; transition: background 0.1s; }
  .bl:last-child { border-bottom: none; }
  .bl:hover { background: var(--bg-hover); }
  .blln { text-align: right; padding: 0 14px; color: var(--text-muted); border-right: 1px solid var(--border); user-select: none; }
  .blcat { padding: 0 10px; font-size: 10px; font-weight: 500; display: flex; align-items: center; }
  .blcat.d { color: var(--cat-DARK); }
  .blcat.b { color: var(--cat-BLOG); }
  .blcat.p { color: var(--cat-PROJECT); }
  .blcat.t { color: var(--cat-TECH); }
  .blcat.g { color: var(--cat-DEVLOG); }
  .bldt { font-size: 10px; color: var(--text-muted); display: flex; align-items: center; }
  .blttl { flex: 1; color: var(--text); padding: 0 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: flex; align-items: center; }
  .bl:hover .blttl { color: var(--text-bright); }
  .bl:hover .bldt { color: var(--gray); }
  .blarr { color: var(--text-muted); opacity: 0; padding-right: 8px; transition: opacity 0.1s; }
  .bl:hover .blarr { opacity: 1; }

  /* Status bar */
  .sbar { display: flex; align-items: center; justify-content: space-between; height: 22px; background: var(--border-active); padding: 0 8px; flex-shrink: 0; }
  .sleft, .sright { display: flex; align-items: center; gap: 12px; }
  .si { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-bright); display: flex; align-items: center; gap: 4px; cursor: default; }
  .si.cl { cursor: pointer; }
  .si.br { color: var(--cyan); font-weight: 700; }
  .si.ac { color: var(--accent); }

  /* Responsive */
  @media (max-width: 768px) {
    .sidebar { display: none; }
    .actbar { display: none; }
    .app { height: auto; min-height: 100vh; }
    .cview { grid-template-columns: 36px 1fr; }
    .bl { grid-template-columns: 36px 50px 1fr; }
    .mbar { flex-wrap: wrap; }
    .mcell { min-width: 50%; border-bottom: 1px solid var(--border); }
  }
</style>

