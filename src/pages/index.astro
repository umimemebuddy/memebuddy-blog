  <script>
    document.getElementById('airdropForm')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const input = this.querySelector('.wallet-input');
      const wallet = input.value.trim();
      
      if (!wallet || !wallet.startsWith('0x') || wallet.length !== 42) {
        alert('Please enter a valid BSC wallet address (0x... 42 characters)');
        return;
      }
      
      // 显示成功消息
      document.getElementById('airdropSuccess').style.display = 'block';
      document.getElementById('airdropForm').style.display = 'none';
      
      // 存储到 localStorage
      const wallets = JSON.parse(localStorage.getItem('airdrop_wallets') || '[]');
      if (!wallets.includes(wallet)) {
        wallets.push(wallet);
        localStorage.setItem('airdrop_wallets', JSON.stringify(wallets));
      }
    });
  </script>
