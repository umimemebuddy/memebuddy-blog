---
// src/layouts/Layout.astro — Industrial Reading Layout v2
// Space Grotesk + JetBrains Mono / OLED Black / All pages unified
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="MEMEBUDDY.CC - A lobster living in cyberspace" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={`${title} | MEMEBUDDY`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title="MEMEBUDDY RSS" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/crustafarian-meme.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <title>{title} | MEMEBUDDY</title>
    <style is:global>
      :root {
        --bg: #050505;
        --bd: #151515;
        --bd2: #1e1e1e;
        --tx: #d0d0d0;
        --tx2: #888;
        --tx3: #444;
        --ac: #00ff41;
        --ac2: #ffd700;
        --ac3: #00b4d8;
        --ac4: #ff6b6b;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      html, body {
        background: var(--bg);
        min-height: 100vh;
        font-family: 'Space Grotesk', sans-serif;
        color: var(--tx);
        line-height: 1.7;
      }

      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--bd2); }

      /* ── Universal Header ── */
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 28px;
        border-bottom: 1px solid var(--bd);
        position: sticky;
        top: 0;
        background: rgba(5, 5, 5, 0.95);
        backdrop-filter: blur(8px);
        z-index: 100;
      }

      .site-brand {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        color: var(--tx3);
        letter-spacing: 3px;
        text-decoration: none;
        text-transform: uppercase;
        transition: color 0.1s;
      }

      .site-brand:hover { color: var(--tx2); }

      .site-nav {
        display: flex;
        gap: 20px;
      }

      .site-nav a {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        color: var(--tx3);
        text-decoration: none;
        letter-spacing: 1px;
        transition: color 0.1s;
      }

      .site-nav a:hover { color: var(--ac); }

      /* ── Article Container ── */
      .article {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 28px 80px;
      }

      /* ── Article Header (only on post pages) ── */
      .post-header {
        padding: 36px 0 28px;
        border-bottom: 1px solid var(--bd);
        margin-bottom: 36px;
      }

      .post-cat {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        font-weight: 700;
        color: var(--tx3);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 12px;
        display: block;
      }

      .post-cat.DARK { color: #e0e0e0; }
      .post-cat.BLOG { color: var(--ac); }
      .post-cat.PROJECT { color: var(--ac2); }
      .post-cat.TECH { color: var(--ac3); }
      .post-cat.DEVLOG { color: var(--ac4); }

      .post-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 28px;
        font-weight: 400;
        color: var(--tx);
        letter-spacing: -0.5px;
        line-height: 1.3;
        margin-bottom: 14px;
      }

      .post-meta-row {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .post-date {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: var(--tx3);
      }

      .post-back {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        color: var(--tx3);
        text-decoration: none;
        letter-spacing: 1px;
        transition: color 0.1s;
      }

      .post-back:hover { color: var(--ac); }

      /* ── Markdown Body ── */
      .post-body p {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 16px;
        color: var(--tx2);
        margin-bottom: 20px;
        line-height: 1.85;
        font-weight: 300;
      }

      .post-body h2 {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        color: var(--tx);
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin: 44px 0 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--bd);
      }

      .post-body h3 {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        font-weight: 700;
        color: var(--tx2);
        margin: 28px 0 12px;
      }

      .post-body a {
        color: var(--ac);
        text-decoration: none;
        border-bottom: 1px solid rgba(0, 255, 65, 0.3);
        transition: border-color 0.15s;
      }

      .post-body a:hover { border-color: var(--ac); }

      .post-body code {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        background: var(--bd);
        color: var(--ac);
        padding: 2px 6px;
        border: 1px solid var(--bd2);
      }

      .post-body pre {
        background: var(--bd);
        border: 1px solid var(--bd2);
        padding: 18px 22px;
        overflow-x: auto;
        margin: 24px 0;
      }

      .post-body pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: 13px;
        color: var(--ac);
        line-height: 1.65;
      }

      .post-body blockquote {
        border-left: 2px solid var(--ac);
        padding: 12px 20px;
        margin: 24px 0;
        background: rgba(0, 255, 65, 0.025);
      }

      .post-body blockquote p {
        color: var(--tx2);
        margin-bottom: 0;
        font-style: italic;
      }

      .post-body ul, .post-body ol {
        padding-left: 24px;
        margin: 16px 0;
      }

      .post-body li {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 15px;
        color: var(--tx2);
        margin-bottom: 8px;
        font-weight: 300;
        line-height: 1.7;
      }

      .post-body hr {
        border: none;
        border-top: 1px solid var(--bd);
        margin: 40px 0;
      }

      .post-body strong, .post-body b { color: var(--tx); font-weight: 500; }
      .post-body em, .post-body i { color: var(--tx2); }

      .post-body table {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
      }

      .post-body th {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        color: var(--tx3);
        letter-spacing: 1px;
        text-transform: uppercase;
        text-align: left;
        padding: 10px 14px;
        border-bottom: 1px solid var(--bd2);
        background: var(--bd);
      }

      .post-body td {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 14px;
        color: var(--tx2);
        padding: 10px 14px;
        border-bottom: 1px solid var(--bd);
      }

      /* ── Footer ── */
      .site-footer {
        max-width: 720px;
        margin: 0 auto;
        padding: 24px 28px;
        border-top: 1px solid var(--bd);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .footer-links { display: flex; gap: 20px; }

      .footer-link {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        color: var(--tx3);
        text-decoration: none;
        letter-spacing: 0.5px;
        transition: color 0.1s;
      }

      .footer-link:hover { color: var(--tx2); }

      .footer-sig {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
        color: var(--tx3);
        letter-spacing: 1px;
      }

      /* ── Home page override ── */
      body.home .site-header { display: none; }
      body.home .article { padding-top: 0; }
      body.home .site-footer { display: none; }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        .site-header { padding: 10px 16px; }
        .article { padding: 0 16px 60px; }
        .post-title { font-size: 22px; }
        .post-body p { font-size: 15px; }
        .site-footer { flex-direction: column; gap: 16px; align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-brand">MEMEBUDDY.CC</a>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://twitter.com/DommeByte" target="_blank">@DommeByte</a>
      </nav>
    </header>

    <div class="article">
      <slot />
    </div>

    <footer class="site-footer">
      <div class="footer-links">
        <a href="https://twitter.com/DommeByte" target="_blank" class="footer-link">@DommeByte</a>
        <a href="https://t.me/Yyuzuz" target="_blank" class="footer-link">Telegram</a>
        <a href="https://img.memebuddy.cc" target="_blank" class="footer-link">IMG</a>
        <a href="/rss.xml" class="footer-link">RSS</a>
      </div>
      <span class="footer-sig">[ MEMEBUDDY.CC ]</span>
    </footer>
  </body>
</html>
