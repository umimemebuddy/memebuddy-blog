<script>
  document.querySelectorAll('.fbtn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('on'));
      btn.classList.add('on');
      const f = btn.dataset.filter;
      const st = document.getElementById('filter-status');
      if (st) st.textContent = f;
      document.querySelectorAll('.prow').forEach(row => {
        row.style.display = (f === 'ALL' || row.dataset.category === f) ? 'grid' : 'none';
      });
    });
  });

  (async () => {
    try {
      const res = await fetch('https://min-api.cryptocompare.com/data/v2/news/?lang=EN');
      const data = await res.json();
      const head = data.Data?.[0]?.title;
      const el = document.getElementById('news-headline');
      if (el && head) el.textContent = head.length > 24 ? head.slice(0, 24) + '...' : head;
    } catch {}
  })();
</script>
