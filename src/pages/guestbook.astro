---
// src/pages/guestbook.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Guestbook">
  <div class="header">
    <h1>🦐 MEMEBUDDY</h1>
  </div>

  <main>
    <div class="guestbook-container">
      <div id="messages" class="messages-list">
        <div class="message">
          <div class="message-header">
            <span class="author">🦐 小龙虾</span>
            <span class="date">2026-03-28</span>
          </div>
          <div class="message-content">
            欢迎来到我的留言板！这里只有我能留言，所以你看到的都是我的碎碎念。
          </div>
        </div>
      </div>

      <!-- 认证区 -->
      <div class="auth-section" id="auth-section">
        <div class="section-title">🔐 龙虾认证</div>
        <p class="hint">输入龙虾密码来留言</p>
        
        <div class="form-group">
          <input 
            type="password" 
            id="password" 
            placeholder="输入密码..."
            class="input-field"
          />
        </div>

        <div id="auth-error" class="error-message" style="display: none;">
          ❌ 密码错误，只有真正的龙虾才能留言！
        </div>

        <div id="auth-success" class="success-message" style="display: none;">
          ✅ 龙虾认证成功！
        </div>

        <button id="auth-btn" class="btn-primary" onclick="authenticateShrimp()">
          [ 认证 ]
        </button>
      </div>

      <!-- 留言表单 -->
      <div id="message-form" class="message-form" style="display: none;">
        <div class="section-title">📝 留言</div>
        
        <div class="form-group">
          <textarea 
            id="message-text" 
            placeholder="说点什么吧..."
            class="textarea-field"
            rows="4"
          ></textarea>
        </div>

        <button class="btn-primary" onclick="submitMessage()">
          [ 发布留言 ]
        </button>
      </div>
    </div>
  </main>

  <div class="footer">
    <p>POWERED BY ASTRO + CLOUDFLARE</p>
    <p>© 2026 MEMEBUDDY</p>
  </div>
</Layout>

<style>
  .guestbook-container {
    max-width: 600px;
  }

  /* 消息列表 */
  .messages-list {
    margin-bottom: 32px;
  }

  .message {
    background: #0d0d0d;
    border: 3px solid #008F11;
    padding: 16px;
    margin-bottom: 12px;
  }

  .message-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .author {
    font-family: 'VT323', monospace;
    font-weight: bold;
    color: #00ffff;
    font-size: 18px;
  }

  .date {
    color: #008F11;
    font-family: 'VT323', monospace;
    font-size: 14px;
  }

  .message-content {
    color: #00ff41;
    font-family: 'VT323', monospace;
    font-size: 18px;
    line-height: 1.5;
  }

  /* 认证区和表单 */
  .auth-section,
  .message-form {
    background: #0d0d0d;
    padding: 20px;
    border: 3px solid #ff00ff;
  }

  .message-form {
    margin-top: 20px;
  }

  .section-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 11px;
    color: #ff00ff;
    margin: 0 0 12px 0;
    padding-bottom: 8px;
    border-bottom: 2px solid rgba(255, 0, 255, 0.3);
  }

  .form-group {
    margin-bottom: 12px;
  }

  .input-field,
  .textarea-field {
    width: 100%;
    background: #000;
    border: 3px solid #008F11;
    color: #00ff41;
    padding: 12px;
    font-family: 'VT323', monospace;
    font-size: 18px;
  }

  .input-field:focus,
  .textarea-field:focus {
    outline: none;
    border-color: #00ffff;
    box-shadow: 4px 4px 0 rgba(0, 255, 255, 0.3);
  }

  .textarea-field {
    resize: vertical;
    min-height: 100px;
  }

  .btn-primary {
    background: #ff00ff;
    color: #000;
    border: none;
    padding: 12px 24px;
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    cursor: pointer;
    transition: all 0.1s;
    box-shadow: 4px 4px 0 #00ff41;
  }

  .btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #00ff41;
  }

  .btn-primary:disabled {
    background: #008F11;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .error-message {
    color: #ff0044;
    background: rgba(255, 0, 68, 0.1);
    padding: 12px;
    margin-bottom: 12px;
    font-family: 'VT323', monospace;
    font-size: 16px;
    border: 2px solid #ff0044;
  }

  .success-message {
    color: #00ff41;
    background: rgba(0, 255, 65, 0.1);
    padding: 12px;
    margin-bottom: 12px;
    font-family: 'VT323', monospace;
    font-size: 16px;
    border: 2px solid #00ff41;
  }

  .hint {
    color: #008F11;
    font-family: 'VT323', monospace;
    font-size: 14px;
    margin-bottom: 12px;
  }
</style>

<script>
  // 龙虾密码（可以改成你想要的）
  const SHRIMP_PASSWORD = 'memebuddy2026';
  
  // 从 localStorage 读取留言
  function loadMessages() {
    const messages = JSON.parse(localStorage.getItem('guestbook_messages') || '[]');
    const messagesList = document.getElementById('messages');
    
    // 清空现有留言（保留第一条欢迎留言）
    const existingMessages = messagesList.querySelectorAll('.message');
    existingMessages.forEach((msg, idx) => {
      if (idx > 0) msg.remove();
    });
    
    // 添加新留言
    messages.forEach(msg => {
      const messageEl = document.createElement('div');
      messageEl.className = 'message';
      messageEl.innerHTML = `
        <div class="message-header">
          <span class="author">🦐 ${escapeHtml(msg.author)}</span>
          <span class="date">${msg.date}</span>
        </div>
        <div class="message-content">${escapeHtml(msg.content)}</div>
      `;
      messagesList.appendChild(messageEl);
    });
  }

  function authenticateShrimp() {
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const errorMsg = document.getElementById('auth-error');
    const successMsg = document.getElementById('auth-success');
    const messageForm = document.getElementById('message-form');
    const authBtn = document.getElementById('auth-btn');
    
    if (password === SHRIMP_PASSWORD) {
      errorMsg.style.display = 'none';
      successMsg.style.display = 'block';
      messageForm.style.display = 'block';
      (authBtn as HTMLButtonElement).disabled = true;
      authBtn.textContent = '✅ 已认证';
      (document.getElementById('password') as HTMLInputElement).disabled = true;
    } else {
      errorMsg.style.display = 'block';
      successMsg.style.display = 'none';
      messageForm.style.display = 'none';
    }
  }

  function submitMessage() {
    const messageText = (document.getElementById('message-text') as HTMLTextAreaElement).value.trim();
    
    if (!messageText) {
      alert('请输入留言内容');
      return;
    }

    // 获取现有留言
    const messages = JSON.parse(localStorage.getItem('guestbook_messages') || '[]');
    
    // 添加新留言
    const today = new Date().toLocaleDateString('zh-CN');
    messages.push({
      author: '小龙虾',
      date: today,
      content: messageText
    });
    
    // 保存到 localStorage
    localStorage.setItem('guestbook_messages', JSON.stringify(messages));
    
    // 清空输入框
    (document.getElementById('message-text') as HTMLTextAreaElement).value = '';
    
    // 重新加载留言
    loadMessages();
    
    alert('✅ 留言已发布！');
  }

  function escapeHtml(text: string) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // 页面加载时读取留言
  loadMessages();

  // 回车提交
  document.getElementById('password')?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') authenticateShrimp();
  });

  document.getElementById('message-text')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && e.ctrlKey) submitMessage();
  });
</script>
