< Layout title="Home">
<style>
  :root {
    --bg: #050505;
    --surface: #0a0a0a;
    --border: #151515;
    --border-hi: #222222;
    --border-accent: #00ff41;
    --text: #d0d0d0;
    --text-dim: #606060;
    --text-muted: #2a2a2a;
    --accent: #00ff41;
    --accent-dim: rgba(0, 255, 65, 0.06);
    --text-sidebar: #aaaaaa;
    --bg-active: rgba(0, 255, 65, 0.08);
    --cat-DARK: #e0e0e0;
    --cat-BLOG: #00ff41;
    --cat-PROJECT: #ffd700;
    --cat-TECH: #00b4d8;
    --cat-DEVLOG: #ff6b6b;
  }

  /* Override Layout */
  .article { max-width: 100% !important; padding: 0 !important; }
  body { background: var(--bg) !important; }
  body::before { display: none !important; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border-hi); }

  /* ═══════════════════════════════════════
     APP SHELL
  ═══════════════════════════════════════ */
  .app {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: var(--bg);
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    max-width: 820px;
    margin: 0 auto;
  }

  /* ═══════════════════════════════════════
     TOP BAR
  ═══════════════════════════════════════ */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 36px;
    padding: 0 24px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    flex-shrink: 0;
  }

  .topbar-brand {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .topbar-meta {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
  }

  /* ═══════════════════════════════════════
     HERO
  ═══════════════════════════════════════ */
  .hero {
    padding: 40px 32px 32px;
    border-bottom: 1px solid var(--border);
  }

  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 48px;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -1px;
    line-height: 1;
    margin-bottom: 12px;
  }

  .hero-title em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-desc {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .hero-links {
    display: flex;
    gap: 8px;
  }

  .hlink {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--border-hi);
    text-decoration: none;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: border-color 0.1s, color 0.1s, background 0.1s;
    background: transparent;
  }

  .hlink:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .hlink-arrow {
    transition: transform 0.1s;
  }

  .hlink:hover .hlink-arrow {
    transform: translateX(3px);
  }

  /* ═══════════════════════════════════════
     META ROW
  ═══════════════════════════════════════ */
  .meta-row {
    display: flex;
    border-bottom: 1px solid var(--border);
  }

  .meta-cell {
    flex: 1;
    padding: 14px 20px;
    border-right: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.1s;
    display: block;
  }

  .meta-cell:last-child { border-right: none; }
  .meta-cell:hover { background: var(--surface); }

  .meta-lbl {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    color: var(--text-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .meta-val {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-dim);
  }

  .meta-val.live { color: var(--accent); font-family: 'Space Mono', monospace; font-size: 12px; }
  .meta-val.dim { color: var(--text-muted); font-family: 'Space Mono', monospace; font-size: 11px; }

  /* ═══════════════════════════════════════
     CRYPTO
  ═══════════════════════════════════════ */
  .crypto {
    border-bottom: 1px solid var(--border);
  }

  /* ═══════════════════════════════════════
     FILTER
  ═══════════════════════════════════════ */
  .filter {
    display: flex;
    border-bottom: 1px solid var(--border-hi);
  }

  .fbtn {
    flex: 1;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    background: transparent;
    border: none;
    border-right: 1px solid var(--border-hi);
    padding: 14px 12px;
    cursor: pointer;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: color 0.1s, background 0.1s;
  }

  .fbtn:last-child { border-right: none; }
  .fbtn:hover { color: var(--text); background: var(--surface); }
  .fbtn.on { color: var(--accent); background: var(--accent-dim); }

  /* ═══════════════════════════════════════
     POST LIST - Grid layout
  ═══════════════════════════════════════ */
  .posts {
    border-bottom: 1px solid var(--border);
  }

  .prow {
    display: grid;
    grid-template-columns: 72px 52px 1fr;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.1s;
  }

  .prow:last-child { border-bottom: none; }
  .prow:hover { background: var(--surface); }

  .pdate {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    padding: 0 12px;
    border-right: 1px solid var(--border);
    transition: color 0.1s;
  }

  .prow:hover .pdate { color: var(--text-dim); }

  .pcat {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    padding: 0 10px;
    border-right: 1px solid var(--border);
    letter-spacing: 0.5px;
  }

  .pcat.D { color: var(--text-muted); }
  .pcat.B { color: var(--text-muted); }
  .pcat.P { color: var(--text-muted); }
  .pcat.T { color: var(--text-muted); }
  .pcat.G { color: var(--text-muted); }

  .prow:hover .pcat.D { color: var(--cat-DARK); }
  .prow:hover .pcat.B { color: var(--cat-BLOG); }
  .prow:hover .pcat.P { color: var(--cat-PROJECT); }
  .prow:hover .pcat.T { color: var(--cat-TECH); }
  .prow:hover .pcat.G { color: var(--cat-DEVLOG); }

  .ptitle {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    padding: 0 16px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.1s;
  }

  .prow:hover .ptitle { color: var(--text); }

  /* ═══════════════════════════════════════
     STATUS BAR
  ═══════════════════════════════════════ */
  .statusbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 24px;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .sbar-left {
    display: flex;
    gap: 20px;
  }

  .sbar-item {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .sbar-item.accent { color: var(--accent); }
  .sbar-item.branch { color: #78dce8; font-weight: 700; }

  .sbar-right {
    display: flex;
    gap: 16px;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════ */
  @media (max-width: 640px) {
    .app { border: none; }
    .hero { padding: 24px 16px; }
    .hero-title { font-size: 32px; }
    .topbar { padding: 0 16px; }
    .hero-links { flex-wrap: wrap; }
    .meta-row { flex-wrap: wrap; }
    .meta-cell { min-width: 50%; border-bottom: 1px solid var(--border); }
    .prow { grid-template-columns: 60px 44px 1fr; }
    .ptitle { font-size: 13px; }
    .statusbar { flex-direction: column; gap: 12px; align-items: flex-start; }
  }
</style>

