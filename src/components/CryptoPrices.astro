---
// 加密货币价格组件 - 赛博朋克风格
const API_KEY = '4de650723df045729019ba16f3951a5e';
const symbols = ['BTC', 'ETH', 'SOL', 'BNB', 'XRP', 'DOGE', 'ADA', 'AVAX'];

// 尝试从API获取数据
let cryptoData = [];
let error = null;

try {
  const response = await fetch(
    `https://pro-api.coinmarketcap.com/v1/cryptocurrency/listings/latest?limit=10`,
    {
      headers: {
        'X-CMC_PRO_API_KEY': API_KEY
      }
    }
  );
  
  if (response.ok) {
    const data = await response.json();
    if (data.data && Array.isArray(data.data)) {
      const symbolSet = new Set(symbols);
      cryptoData = data.data
        .filter(coin => symbolSet.has(coin.symbol))
        .map(coin => ({
          symbol: coin.symbol,
          name: coin.name,
          price: coin.quote.USD.price,
          change24h: coin.quote.USD.percent_change_24h
        }));
    }
  } else {
    error = 'API Error: ' + response.status;
  }
} catch (e) {
  error = 'Fetch failed';
}

// 备用数据
const fallbackData = [
  { symbol: 'BTC', name: 'Bitcoin', price: 67432.15, change24h: 2.34 },
  { symbol: 'ETH', name: 'Ethereum', price: 3421.88, change24h: 1.56 },
  { symbol: 'SOL', name: 'Solana', price: 142.65, change24h: -0.89 },
  { symbol: 'BNB', name: 'BNB', price: 582.33, change24h: 0.45 },
  { symbol: 'XRP', name: 'XRP', price: 0.5234, change24h: -1.23 },
  { symbol: 'DOGE', name: 'Dogecoin', price: 0.0823, change24h: 3.21 },
  { symbol: 'ADA', name: 'Cardano', price: 0.4532, change24h: -0.67 },
  { symbol: 'AVAX', name: 'Avalanche', price: 35.67, change24h: 1.89 }
];

const displayData = cryptoData.length > 0 ? cryptoData : fallbackData;
---

<div class="crypto-section">
  <div class="crypto-header">
    <span class="crypto-icon">◈</span>
    <span class="crypto-title">CRYPTO MARKET</span>
    <span class="crypto-subtitle">Live prices via CoinMarketCap</span>
  </div>
  <div class="crypto-grid">
    {displayData.map((coin) => (
      <div class="crypto-card">
        <div class="crypto-symbol">{coin.symbol}</div>
        <div class="crypto-name">{coin.name}</div>
        <div class="crypto-price">${coin.price < 1 ? coin.price.toFixed(4) : coin.price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</div>
        <div class={`crypto-change ${coin.change24h >= 0 ? 'positive' : 'negative'}`}>
          {coin.change24h >= 0 ? '▲' : '▼'} {Math.abs(coin.change24h).toFixed(2)}%
        </div>
      </div>
    ))}
  </div>
  {error && <div class="crypto-error">⚠ {error} - Using cached data</div>}
</div>

<style>
  .crypto-section {
    background: linear-gradient(180deg, rgba(88, 28, 135, 0.15) 0%, rgba(0, 0, 0, 0.95) 50%, rgba(6, 78, 59, 0.15) 100%);
    border: 3px solid;
    border-image: linear-gradient(90deg, #ff00ff, #00ffff, #ffff00, #ff00ff) 1;
    border-radius: 8px;
    padding: 24px;
    margin: 20px 0;
    position: relative;
    overflow: hidden;
  }

  .crypto-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255, 255, 255, 0.03) 2px,
      rgba(255, 255, 255, 0.03) 4px
    );
    pointer-events: none;
    animation: scanlines 6s linear infinite;
  }

  .crypto-section::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(from 0deg, transparent 0deg, rgba(255, 0, 255, 0.1) 60deg, transparent 120deg, rgba(0, 255, 255, 0.1) 180deg, transparent 240deg, rgba(255, 255, 0, 0.1) 300deg, transparent 360deg);
    animation: rotate 10s linear infinite;
    pointer-events: none;
  }

  @keyframes scanlines {
    0% { transform: translateY(0); }
    100% { transform: translateY(4px); }
  }

  @keyframes rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .crypto-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid transparent;
    border-image: linear-gradient(90deg, #ff00ff, #00ffff) 1;
    position: relative;
    z-index: 1;
  }

  .crypto-icon {
    font-size: 28px;
    background: linear-gradient(90deg, #ff00ff, #00ffff, #ffff00);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: rainbow 3s linear infinite;
    filter: drop-shadow(0 0 10px rgba(255, 0, 255, 0.8));
  }

  @keyframes rainbow {
    0% { filter: hue-rotate(0deg) drop-shadow(0 0 10px #ff00ff); }
    50% { filter: hue-rotate(180deg) drop-shadow(0 0 10px #00ffff); }
    100% { filter: hue-rotate(360deg) drop-shadow(0 0 10px #ff00ff); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }

  .crypto-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 14px;
    background: linear-gradient(90deg, #ff00ff, #00ffff, #ffff00, #ff00ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 300% 100%;
    animation: gradient-shift 4s ease infinite;
    letter-spacing: 2px;
    text-shadow: none;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .crypto-subtitle {
    font-family: 'VT323', monospace;
    font-size: 14px;
    background: linear-gradient(90deg, #00ffff, #ff00ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-left: auto;
  }

  .crypto-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    position: relative;
    z-index: 1;
  }

  .crypto-card {
    background: linear-gradient(135deg, rgba(88, 28, 135, 0.4) 0%, rgba(6, 78, 59, 0.4) 100%);
    border: 1px solid rgba(255, 0, 255, 0.3);
    border-radius: 8px;
    padding: 12px;
    text-align: center;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .crypto-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }

  .crypto-card:hover::before {
    left: 100%;
  }

  .crypto-card:hover {
    border-color: #00ffff;
    box-shadow: 0 0 25px rgba(0, 255, 255, 0.5), inset 0 0 20px rgba(0, 255, 255, 0.1);
    transform: translateY(-4px) scale(1.02);
  }

  .crypto-symbol {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    background: linear-gradient(90deg, #ff00ff, #00ffff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 4px;
  }

  .crypto-name {
    font-family: 'VT323', monospace;
    font-size: 12px;
    color: #e0e0e0;
    margin-bottom: 8px;
  }

  .crypto-price {
    font-family: 'VT323', monospace;
    font-size: 18px;
    background: linear-gradient(90deg, #fff, #00ffff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 4px;
  }

  .crypto-change {
    font-family: 'VT323', monospace;
    font-size: 14px;
    font-weight: bold;
  }

  .crypto-change.positive {
    color: #00ff88;
    text-shadow: 0 0 10px rgba(0, 255, 136, 0.8);
  }

  .crypto-change.negative {
    color: #ff3366;
    text-shadow: 0 0 10px rgba(255, 51, 102, 0.8);
  }

  .crypto-error {
    margin-top: 12px;
    padding: 8px;
    background: rgba(255, 51, 102, 0.2);
    border: 1px solid #ff3366;
    border-radius: 4px;
    font-family: 'VT323', monospace;
    font-size: 14px;
    color: #ff3366;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .crypto-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .crypto-header {
      flex-wrap: wrap;
    }
    .crypto-subtitle {
      width: 100%;
      margin-left: 0;
      margin-top: 8px;
    }
  }
</style>
