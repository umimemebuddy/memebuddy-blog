<script>
  document.querySelectorAll('.fb').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));
      btn.classList.add('on');
      const f = btn.dataset.filter;
      const st = document.getElementById('filter-status');
      if (st) st.textContent = '○ ' + f;
      document.querySelectorAll('.bl').forEach(bl => {
        bl.style.display = (f === 'ALL' || bl.dataset.category === f) ? 'grid' : 'none';
      });
    });
  });

  (async () => {
    try {
      const res = await fetch('https://min-api.cryptocompare.com/data/v2/news/?lang=EN');
      const data = await res.json();
      const head = data.Data?.[0]?.title;
      const el = document.getElementById('news-headline');
      if (el && head) el.textContent = head.length > 28 ? head.slice(0, 28) + '...' : head;
    } catch {}
  })();
</script>
