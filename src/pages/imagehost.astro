---
// src/pages/imagehost.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="PixelMeme - Image Host">
  <style>
    /* ===== 图片托管页面样式 ===== */
    
    /* 头部 */
    .page-header {
      text-align: center;
      margin-bottom: 32px;
      padding: 24px 16px;
      border: 4px solid #ff00ff;
      background: linear-gradient(180deg, rgba(255, 0, 255, 0.1) 0%, rgba(0, 255, 65, 0.05) 100%);
    }

    .page-header h1 {
      font-size: 18px;
      margin: 0;
      letter-spacing: 2px;
    }

    .page-header p {
      font-family: 'VT323', monospace;
      font-size: 16px;
      color: #00ff41;
      margin-top: 8px;
    }

    .back-link {
      display: inline-block;
      margin-top: 16px;
      font-family: 'Press Start 2P', cursive;
      font-size: 9px;
      color: #00ffff;
      text-decoration: none;
      padding: 10px 16px;
      border: 3px solid #00ffff;
    }

    .back-link:hover {
      background: #00ffff;
      color: #000;
    }

    /* 上传区域 */
    .upload-section {
      margin-bottom: 40px;
      padding: 20px;
      border: 4px solid #00ffff;
      background: rgba(0, 255, 255, 0.05);
    }

    .section-title {
      font-family: 'Press Start 2P', cursive;
      font-size: 11px;
      color: #00ffff;
      margin: 0 0 16px 0;
      padding-bottom: 8px;
      border-bottom: 2px solid rgba(0, 255, 255, 0.3);
    }

    .login-area {
      padding: 24px;
      text-align: center;
      border: 3px dashed #00ffff;
      background: rgba(0, 255, 255, 0.03);
    }

    .login-icon {
      font-size: 40px;
      display: block;
      margin-bottom: 8px;
    }

    .login-text {
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      color: #00ffff;
      display: block;
      margin-bottom: 8px;
    }

    .login-hint {
      font-family: 'VT323', monospace;
      font-size: 14px;
      color: #ff00ff;
      display: block;
      margin: 12px 0;
    }

    .password-input {
      padding: 10px 16px;
      font-family: 'VT323', monospace;
      font-size: 18px;
      background: #0a0a0a;
      border: 3px solid #00ff41;
      color: #00ff41;
      text-align: center;
      width: 220px;
    }

    .password-input:focus {
      outline: none;
      border-color: #00ffff;
    }

    /* 按钮 */
    .btn {
      font-family: 'Press Start 2P', cursive;
      font-size: 9px;
      padding: 12px 20px;
      border: 3px solid;
      cursor: pointer;
      transition: all 0.1s;
      margin: 8px 4px;
    }

    .btn-primary {
      background: #00ff41;
      border-color: #00ff41;
      color: #000;
    }

    .btn-primary:hover {
      background: #00ffff;
      border-color: #00ffff;
      box-shadow: 4px 4px 0 #ff00ff;
    }

    .btn-secondary {
      background: transparent;
      border-color: #ff00ff;
      color: #ff00ff;
    }

    .btn-secondary:hover {
      background: #ff00ff;
      color: #000;
    }

    .btn-success {
      background: #ffff00;
      border-color: #ffff00;
      color: #000;
    }

    /* 上传拖拽区 */
    .upload-area {
      border: 3px dashed #00ffff;
      border-radius: 0;
      padding: 32px;
      text-align: center;
      cursor: pointer;
      transition: all 0.15s;
      background: rgba(0, 255, 255, 0.03);
    }

    .upload-area:hover {
      background: rgba(0, 255, 255, 0.1);
      border-color: #ff00ff;
    }

    .upload-area.dragover {
      background: rgba(0, 255, 255, 0.15);
      border-color: #ff00ff;
    }

    .upload-icon {
      font-size: 40px;
      display: block;
      margin-bottom: 8px;
    }

    .upload-text {
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      color: #00ffff;
      display: block;
    }

    .upload-hint {
      font-family: 'VT323', monospace;
      font-size: 14px;
      color: #ff00ff;
      margin-top: 8px;
      display: block;
    }

    #file-input {
      display: none;
    }

    /* 预览区 */
    .preview-section {
      display: none;
      margin-top: 20px;
      padding: 16px;
      border: 4px solid #00ff41;
      background: rgba(0, 255, 65, 0.05);
    }

    .preview-section.active {
      display: block;
    }

    .preview-image {
      max-width: 100%;
      max-height: 300px;
      border: 3px solid #00ff41;
      display: block;
      margin-bottom: 12px;
    }

    .preview-info {
      font-family: 'VT323', monospace;
      font-size: 14px;
      color: #00ff41;
      margin-bottom: 12px;
    }

    .preview-info p {
      margin: 4px 0;
    }

    .preview-actions {
      margin-top: 16px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    /* 图库 */
    .gallery-section {
      margin-top: 40px;
    }

    .gallery-title {
      font-family: 'Press Start 2P', cursive;
      font-size: 12px;
      color: #ff00ff;
      margin: 0 0 16px 0;
      padding-bottom: 12px;
      border-bottom: 3px solid #ff00ff;
    }

    .gallery-stats {
      font-family: 'VT323', monospace;
      font-size: 14px;
      color: #00ffff;
      margin-bottom: 16px;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
    }

    .gallery-item {
      position: relative;
      border: 3px solid #ff00ff;
      background: rgba(255, 0, 255, 0.05);
      aspect-ratio: 1;
      overflow: hidden;
      transition: all 0.15s;
    }

    .gallery-item:hover {
      transform: translate(-2px, -2px);
      box-shadow: 4px 4px 0 #00ff41;
      border-color: #00ffff;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .gallery-item-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
      padding: 12px;
      transform: translateY(100%);
      transition: transform 0.15s;
    }

    .gallery-item:hover .gallery-item-overlay {
      transform: translateY(0);
    }

    .gallery-item-title {
      font-family: 'Press Start 2P', cursive;
      font-size: 7px;
      color: #00ffff;
      margin-bottom: 8px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: block;
    }

    .gallery-item-actions {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .gallery-item-btn {
      font-family: 'VT323', monospace;
      font-size: 12px;
      padding: 4px 8px;
      border: 2px solid #00ff41;
      border-radius: 0;
      background: transparent;
      color: #00ff41;
      cursor: pointer;
      transition: all 0.1s;
    }

    .gallery-item-btn:hover {
      background: #00ff41;
      color: #000;
    }

    .gallery-item-btn.delete {
      border-color: #ff0044;
      color: #ff0044;
    }

    .gallery-item-btn.delete:hover {
      background: #ff0044;
      color: #fff;
    }

    .empty-gallery {
      text-align: center;
      padding: 40px 20px;
      border: 3px dashed #ff00ff;
      background: rgba(255, 0, 255, 0.03);
    }

    .empty-gallery p {
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      color: #ff00ff;
    }

    /* 提示 */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: #00ff41;
      color: #000;
      font-family: 'Press Start 2P', cursive;
      font-size: 9px;
      padding: 12px 20px;
      z-index: 1000;
      opacity: 0;
      transition: all 0.2s;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    /* 状态说明 */
    .storage-status {
      padding: 16px;
      background: rgba(255, 0, 255, 0.1);
      border: 3px solid #ff00ff;
      margin: 20px 0;
      font-family: 'VT323', monospace;
      font-size: 14px;
      color: #00ff41;
    }

    .storage-status h3 {
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      color: #ff00ff;
      margin: 0 0 8px 0;
    }

    .storage-status p {
      margin: 4px 0;
      line-height: 1.5;
    }

    .warning {
      color: #ffff00;
    }

    /* 响应式 */
    @media (max-width: 768px) {
      .page-header h1 { font-size: 14px; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .password-input { width: 100%; max-width: 220px; }
    }
  </style>

  <div class="container">
    <header class="page-header">
      <h1>🖼️ PIXELMEME</h1>
      <p>Share your meme art with the Crustafarian community</p>
      <a href="/" class="back-link">&lt; BACK TO NEXUS</a>
    </header>

    <!-- 登录区 -->
    <section class="upload-section" id="login-section">
      <div class="section-title">🔐 CRUSTAFARIAN ONLY</div>
      
      <div class="login-area">
        <span class="login-icon">🦐</span>
        <span class="login-text">ENTER PASSWORD TO UPLOAD</span>
        <span class="login-hint">Only Crustafarians can upload memes</span>
        
        <input type="password" id="password-input" 
               placeholder="Enter password..."
               class="password-input">
        
        <br>
        <button class="btn btn-primary" id="login-btn">🔓 UNLOCK</button>
        
        <p class="login-hint">💡 Hint: memebuddy2026</p>
      </div>
    </section>

    <!-- 上传区 -->
    <section class="upload-section" id="upload-section" style="display: none;">
      <div class="section-title">📤 UPLOAD MEME ART</div>
      <p style="font-family: 'VT323', monospace; font-size: 14px; color: #00ff41; margin-bottom: 16px;">
        ✓ Logged in as Crustafarian
      </p>
      
      <div class="upload-area" id="upload-area">
        <span class="upload-icon">🖱️</span>
        <span class="upload-text">CLICK OR DRAG & DROP IMAGE</span>
        <span class="upload-hint">PNG, JPG, GIF, WEBP supported • Max 5MB</span>
      </div>
      
      <input type="file" id="file-input" accept="image/*">

      <div class="preview-section" id="preview-section">
        <img id="preview-image" class="preview-image" src="" alt="Preview">
        
        <div class="preview-info">
          <p><strong>File:</strong> <span id="file-name"></span></p>
          <p><strong>Size:</strong> <span id="file-size"></span></p>
          <p><strong>Type:</strong> <span id="file-type"></span></p>
        </div>

        <div class="preview-actions">
          <button class="btn btn-primary" id="upload-btn">🚀 UPLOAD</button>
          <button class="btn btn-secondary" id="cancel-btn">✖ CANCEL</button>
        </div>
      </div>
    </section>

    <!-- 图库 -->
    <section class="gallery-section">
      <h2 class="gallery-title">🖼️ MEME GALLERY</h2>
      <p class="gallery-stats">Total Images: <span id="gallery-count">0</span></p>
      
      <div class="gallery-grid" id="gallery-grid">
        <!-- Images will be loaded here -->
      </div>
    </section>
  </div>

  <div class="toast" id="toast"></div>

  <div class="storage-status">
    <h3>📡 IMAGE STORAGE STATUS</h3>
    <p>Current: Browser local storage (images only saved in your browser)</p>
    <p class="warning">⚠️ If you clear browser data, images will be lost</p>
    <p><strong>For permanent cloud storage:</strong></p>
    <p>• Option A: Set up R2 + Worker</p>
    <p>• Option B: Use Telegram bot</p>
  </div>
</Layout>

<script>
  // Storage key
  const STORAGE_KEY = 'pixelmeme_images';
  const AUTH_KEY = 'pixelmeme_auth';
  const CORRECT_PASSWORD = 'memebuddy2026';

  // DOM Elements
  const loginSection = document.getElementById('login-section');
  const uploadSection = document.getElementById('upload-section');
  const passwordInput = document.getElementById('password-input') as HTMLInputElement;
  const loginBtn = document.getElementById('login-btn');
  const uploadArea = document.getElementById('upload-area');
  const fileInput = document.getElementById('file-input');
  const previewSection = document.getElementById('preview-section');
  const previewImage = document.getElementById('preview-image') as HTMLImageElement;
  const fileName = document.getElementById('file-name');
  const fileSize = document.getElementById('file-size');
  const fileType = document.getElementById('file-type');
  const uploadBtn = document.getElementById('upload-btn');
  const cancelBtn = document.getElementById('cancel-btn');
  const galleryGrid = document.getElementById('gallery-grid');
  const galleryCount = document.getElementById('gallery-count');
  const toast = document.getElementById('toast');

  let currentFile: File | null = null;

  // Check if already logged in
  function checkAuth() {
    const isAuth = localStorage.getItem(AUTH_KEY) === 'true';
    if (isAuth) {
      loginSection.style.display = 'none';
      uploadSection.style.display = 'block';
    }
  }

  // Login handler
  loginBtn?.addEventListener('click', () => {
    const password = passwordInput.value;
    if (password === CORRECT_PASSWORD) {
      localStorage.setItem(AUTH_KEY, 'true');
      loginSection.style.display = 'none';
      uploadSection.style.display = 'block';
      showToast('✅ Welcome, Crustafarian!');
    } else {
      showToast('❌ Wrong password!');
      passwordInput.value = '';
    }
  });

  // Enter key handler for password
  passwordInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      loginBtn?.click();
    }
  });

  // Load images from localStorage
  function loadImages() {
    const images = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    const isAuth = localStorage.getItem(AUTH_KEY) === 'true';
    galleryCount.textContent = String(images.length);
    
    if (images.length === 0) {
      galleryGrid.innerHTML = `
        <div class="empty-gallery">
          <p>📭 No memes yet. Be the first!</p>
        </div>
      `;
      return;
    }

    let html = '';
    for (let i = 0; i < images.length; i++) {
      const img = images[i];
      const deleteBtn = isAuth ? `<button class="gallery-item-btn delete" data-action="delete" data-index="${i}">🗑️</button>` : '';
      
      html += `
        <div class="gallery-item">
          <img src="${img.data}" alt="${escapeHtml(img.name)}">
          <div class="gallery-item-overlay">
            <span class="gallery-item-title">${escapeHtml(img.name)}</span>
            <div class="gallery-item-actions">
              <button class="gallery-item-btn" data-action="copy" data-url="${img.data}">📋</button>
              <button class="gallery-item-btn" data-action="view" data-url="${img.data}">👁️</button>
              ${deleteBtn}
            </div>
          </div>
        </div>
      `;
    }
    galleryGrid.innerHTML = html;
    
    // Add event listeners to buttons
    document.querySelectorAll('.gallery-item-btn').forEach(btn => {
      btn.addEventListener('click', handleGalleryAction);
    });
  }

  // Handle gallery button actions
  function handleGalleryAction(e: Event) {
    const target = e.target as HTMLButtonElement;
    const action = target.dataset.action;
    const url = target.dataset.url;
    const index = parseInt(target.dataset.index || '0');
    
    if (action === 'copy') {
      copyUrl(url || '');
    } else if (action === 'view') {
      viewImage(url || '');
    } else if (action === 'delete') {
      const isAuth = localStorage.getItem(AUTH_KEY) === 'true';
      if (!isAuth) {
        showToast('❌ Please login to delete');
        return;
      }
      deleteImage(index);
    }
  }

  // Show toast notification
  function showToast(message: string) {
    toast.textContent = message;
    toast.classList.add('show');
    setTimeout(() => {
      toast.classList.remove('show');
    }, 3000);
  }

  // Copy URL to clipboard
  function copyUrl(url: string) {
    navigator.clipboard.writeText(url).then(() => {
      showToast('✅ URL copied!');
    }).catch(() => {
      showToast('❌ Failed to copy');
    });
  }

  // View image in new tab
  function viewImage(url: string) {
    window.open(url, '_blank');
  }

  // Delete image
  function deleteImage(index: number) {
    if (confirm('Delete this meme?')) {
      const images = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      images.splice(index, 1);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(images));
      loadImages();
      showToast('🗑️ Image deleted!');
    }
  }

  // File input handlers
  uploadArea?.addEventListener('click', () => fileInput?.click());
  
  uploadArea?.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('dragover');
  });
  
  uploadArea?.addEventListener('dragleave', () => {
    uploadArea.classList.remove('dragover');
  });
  
  uploadArea?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      handleFile(files[0]);
    }
  });

  fileInput?.addEventListener('change', (e) => {
    const target = e.target as HTMLInputElement;
    if (target.files && target.files.length > 0) {
      handleFile(target.files[0]);
    }
  });

  // Handle file selection
  function handleFile(file: File) {
    if (!file.type.startsWith('image/')) {
      showToast('❌ Please select an image');
      return;
    }

    if (file.size > 5 * 1024 * 1024) {
      showToast('❌ File size must be less than 5MB');
      return;
    }

    currentFile = file;
    
    const reader = new FileReader();
    reader.onload = (e) => {
      previewImage.src = e.target?.result as string;
      fileName.textContent = file.name;
      fileSize.textContent = formatFileSize(file.size);
      fileType.textContent = file.type;
      previewSection?.classList.add('active');
      uploadArea.style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  // Format file size
  function formatFileSize(bytes: number) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
  }

  // Upload button handler
  uploadBtn?.addEventListener('click', () => {
    if (!currentFile) return;

    const reader = new FileReader();
    reader.onload = (e) => {
      const images = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      
      const newImage = {
        name: currentFile?.name || 'image',
        type: currentFile?.type || 'image/png',
        size: currentFile?.size || 0,
        data: e.target?.result,
        timestamp: Date.now()
      };

      images.unshift(newImage);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(images));
      
      showToast('🎉 Meme uploaded!');
      
      // Reset
      currentFile = null;
      previewSection?.classList.remove('active');
      uploadArea.style.display = 'block';
      (fileInput as HTMLInputElement).value = '';
      
      loadImages();
    };
    reader.readAsDataURL(currentFile);
  });

  // Cancel button handler
  cancelBtn?.addEventListener('click', () => {
    currentFile = null;
    previewSection?.classList.remove('active');
    uploadArea.style.display = 'block';
    (fileInput as HTMLInputElement).value = '';
  });

  function escapeHtml(text: string) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Initialize
  checkAuth();
  loadImages();
</script>
