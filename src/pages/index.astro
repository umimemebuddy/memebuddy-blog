---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">

<Layout title="Home">
  <style>
    /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?       CODE EDITOR THEME v4 鈥?VSCode Dark / Monokai Pro
       鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/

    :root {
      /* VSCode Dark+ palette */
      --bg-app: #1e1e1e;
      --bg-sidebar: #181818;
      --bg-titlebar: #323233;
      --bg-tab: #2d2d2d;
      --bg-editor: #1e1e1e;
      --bg-hover: #2a2d2e;
      --bg-active: #094771;
      --bg-line-highlight: #2d2d2d;
      
      --border: #3c3c3c;
      --border-tab: #252526;
      --border-active: #007acc;
      
      /* Monokai Pro syntax */
      --pink:      #ff6188;
      --orange:    #ffb443;
      --yellow:    #ffd47a;
      --green:     #a9dc76;
      --cyan:      #78dce8;
      --blue:      #7aa2f7;
      --purple:    #ab9df2;
      --red:       #ff5c5c;
      --comment:   #5c6370;
      --gray:      #9da5b4;
      
      --cat-DARK:    var(--pink);
      --cat-BLOG:    var(--green);
      --cat-PROJECT: var(--yellow);
      --cat-TECH:    var(--cyan);
      --cat-DEVLOG:  var(--orange);
      
      --text: #cbd0d4;
      --text-dim: #7a7a7a;
      --text-bright: #f5f5f5;
      --text-muted: #4a4a4a;
      --text-sidebar: #cccccc;
      
      --accent: var(--green);
      
      --scrollbar: #424242;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--scrollbar); }
    ::-webkit-scrollbar-corner { background: transparent; }

    /* Override Layout */
    .article { max-width: 100% !important; padding: 0 !important; }
    body { background: var(--bg-app) !important; }
    body::before { display: none !important; }

    /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?       APP SHELL
    鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/

    .app {
      display: flex;
      flex-direction: column;
      height: 100vh;
      background: var(--bg-app);
      overflow: hidden;
    }

    /* 鈹€鈹€ Title Bar 鈹€鈹€ */
    .titlebar {
      display: flex;
      align-items: center;
      height: 28px;
      background: var(--bg-titlebar);
      border-bottom: 1px solid var(--border-tab);
      flex-shrink: 0;
    }

    .titlebar-dots {
      display: flex;
      gap: 8px;
      padding: 0 12px;
    }

    .dot { width: 12px; height: 12px; border-radius: 50%; cursor: pointer; }
    .dot-close { background: #ff5f56; }
    .dot-min   { background: #ffbd2e; }
    .dot-max   { background: #27c93f; }

    .titlebar-title {
      flex: 1;
      text-align: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--text-dim);
    }

    .titlebar-title .sep { color: var(--text-muted); margin: 0 6px; }
    .titlebar-title .file { color: var(--gray); }

    .titlebar-spacer { width: 76px; }

    /* 鈹€鈹€ Main Layout 鈹€鈹€ */
    .main-area {
      display: flex;
      flex: 1;
      overflow: hidden;
    }

    /* 鈹€鈹€ Activity Bar 鈹€鈹€ */
    .activity-bar {
      width: 44px;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border-tab);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 8px 0;
      flex-shrink: 0;
    }

    .act-btn {
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      color: var(--text-muted);
      cursor: pointer;
      background: none;
      border: none;
      transition: all 0.1s;
      position: relative;
    }

    .act-btn:hover { color: var(--gray); }
    .act-btn.active { color: var(--gray); }
    .act-btn.active::before {
      content: '';
      position: absolute;
      left: 0; top: 50%;
      transform: translateY(-50%);
      width: 2px; height: 20px;
      background: var(--accent);
    }

    .act-spacer { flex: 1; }

    .act-btn .badge {
      position: absolute;
      top: 6px; right: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 8px;
      background: var(--pink);
      color: white;
      padding: 1px 3px;
      line-height: 1.2;
    }

    /* 鈹€鈹€ Sidebar 鈹€鈹€ */
    .sidebar {
      width: 220px;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      overflow: hidden;
    }

    .sidebar-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 14px 8px;
    }

    .sidebar-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-muted);
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .sidebar-add {
      font-size: 16px;
      color: var(--text-muted);
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      line-height: 1;
    }

    .sidebar-add:hover { color: var(--gray); }

    .tree {
      flex: 1;
      overflow-y: auto;
      padding-bottom: 16px;
    }

    .tree-section { margin-bottom: 4px; }

    .tree-head {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 4px 12px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-muted);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      cursor: pointer;
    }

    .tree-head:hover { color: var(--gray); }
    .tree-chevron { font-size: 8px; transition: transform 0.15s; }
    .tree-head.open .tree-chevron { transform: rotate(90deg); }

    .tree-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 12px 5px 20px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--text-sidebar);
      cursor: pointer;
      text-decoration: none;
      border: none;
      transition: background 0.1s;
    }

    .tree-item:hover { background: var(--bg-hover); }

    .tree-item.active {
      background: var(--bg-active);
      color: var(--text-bright);
    }

    .tree-icon { font-size: 11px; opacity: 0.6; flex-shrink: 0; }
    .tree-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* 鈹€鈹€ Editor Area 鈹€鈹€ */
    .editor-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: var(--bg-editor);
    }

    /* Tabs */
    .tabs {
      display: flex;
      background: var(--bg-tab);
      border-bottom: 1px solid var(--border);
      overflow-x: auto;
      flex-shrink: 0;
    }

    .tabs::-webkit-scrollbar { height: 2px; }

    .tab {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--text-dim);
      border-right: 1px solid var(--border);
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.1s;
      background: transparent;
      border-bottom: none;
      flex-shrink: 0;
    }

    .tab:hover { background: var(--bg-hover); color: var(--gray); }

    .tab.active {
      background: var(--bg-editor);
      color: var(--text-bright);
      border-bottom: 1px solid var(--bg-editor);
      margin-bottom: -1px;
    }

    .tab-icon { font-size: 10px; opacity: 0.5; }
    .tab-name { font-size: 11px; }
    .tab-close { font-size: 12px; color: var(--text-muted); opacity: 0; margin-left: 4px; }
    .tab:hover .tab-close { opacity: 1; }
    .tab-close:hover { color: var(--text-bright); }

    /* Breadcrumb */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 0 16px;
      height: 22px;
      background: var(--bg-sidebar);
      border-bottom: 1px solid var(--border);
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      color: var(--text-muted);
      flex-shrink: 0;
    }

    .crumb-item { cursor: pointer; transition: color 0.1s; }
    .crumb-item:hover { color: var(--gray); }
    .crumb-sep { font-size: 8px; color: var(--text-muted); }
    .crumb-item.current { color: var(--gray); cursor: default; }

    /* Scrollable editor */
    .editor-scroll {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
    }

    /* Code view */
    .code-view {
      display: grid;
      grid-template-columns: 52px 1fr;
      min-height: 100%;
    }

    /* Line numbers */
    .line-nums {
      background: var(--bg-editor);
      border-right: 1px solid var(--border);
      padding: 16px 0;
      user-select: none;
      position: sticky;
      left: 0;
    }

    .ln {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--text-muted);
      text-align: right;
      padding: 0 14px;
      line-height: 1.75;
    }

    .ln.active-line {
      color: var(--gray);
      background: var(--bg-line-highlight);
    }

    /* Code body */
    .code-body {
      padding: 16px 24px 16px 20px;
    }

    /* 鈹€鈹€ File header comment 鈹€鈹€ */
    .file-header { margin-bottom: 20px; }

    .comment-block {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      line-height: 1.8;
      margin-bottom: 12px;
    }

    .c { color: var(--comment); }
    .ck { color: var(--pink); }
    .cs { color: var(--yellow); }
    .cf { color: var(--cyan); }
    .cn { color: var(--purple); }

    .hero-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 26px;
      font-weight: 700;
      color: var(--text-bright);
      letter-spacing: -0.5px;
      margin-bottom: 10px;
    }

    .hero-title .kw { color: var(--cyan); }
    .hero-title .fn { color: var(--green); font-weight: 400; }

    .hero-desc {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: var(--gray);
      line-height: 1.7;
      max-width: 520px;
      margin-bottom: 16px;
    }

    .cursor {
      display: inline-block;
      width: 2px;
      height: 14px;
      background: var(--accent);
      vertical-align: middle;
      animation: cur-blink 1s step-end infinite;
    }

    @keyframes cur-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* 鈹€鈹€ Meta bar 鈹€鈹€ */
    .meta-bar {
      display: flex;
      border: 1px solid var(--border);
      margin-bottom: 16px;
    }

    .meta-cell {
      flex: 1;
      padding: 12px 14px;
      border-right: 1px solid var(--border);
      transition: background 0.1s;
      cursor: default;
      text-decoration: none;
      display: block;
    }

    .meta-cell:last-child { border-right: none; }
    .meta-cell:hover { background: var(--bg-hover); }

    .meta-lbl {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      font-weight: 700;
      color: var(--text-muted);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .meta-val {
      font-family: 'Fira Code', monospace;
      font-size: 13px;
      color: var(--text);
    }

    .meta-val.kw { color: var(--pink); }
    .meta-val.live { color: var(--accent); }
    .meta-val.dim { color: var(--text-dim); }

    /* 鈹€鈹€ Imports 鈹€鈹€ */
    .imports {
      font-family: 'Fira Code', monospace;
      font-size: 12px;
      margin-bottom: 16px;
      border-left: 2px solid var(--border-active);
      padding-left: 12px;
    }

    .import-line {
      color: var(--comment);
      margin-bottom: 4px;
      line-height: 1.6;
    }

    .import-line .k { color: var(--pink); }
    .import-line .p { color: var(--yellow); }
    .import-line .f { color: var(--cyan); }

    /* 鈹€鈹€ Filter 鈹€鈹€ */
    .filter {
      display: flex;
      border: 1px solid var(--border);
      border-bottom: none;
      margin-bottom: 0;
    }

    .fbtn {
      flex: 1;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-muted);
      background: transparent;
      border: none;
      border-right: 1px solid var(--border);
      padding: 10px 12px;
      cursor: pointer;
      letter-spacing: 1px;
      transition: all 0.1s;
    }

    .fbtn:last-child { border-right: none; }
    .fbtn:hover { background: var(--bg-hover); color: var(--gray); }
    .fbtn.active { background: var(--bg-active); color: var(--text-bright); }

    /* 鈹€鈹€ Code block (post list) 鈹€鈹€ */
    .code-block {
      border: 1px solid var(--border);
      border-top: none;
      margin-bottom: 16px;
    }

    .block-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6px 14px;
      background: var(--bg-sidebar);
      border-bottom: 1px solid var(--border);
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
    }

    .block-label { color: var(--comment); }
    .block-count { color: var(--text-muted); }

    .bline {
      display: grid;
      grid-template-columns: 52px 64px 1fr;
      font-family: 'Fira Code', monospace;
      font-size: 12px;
      line-height: 1.75;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: background 0.1s;
    }

    .bline:last-child { border-bottom: none; }
    .bline:hover { background: var(--bg-hover); }

    .bline-ln {
      text-align: right;
      padding: 0 14px;
      color: var(--text-muted);
      border-right: 1px solid var(--border);
      user-select: none;
    }

    .bline-cat {
      padding: 0 10px;
      font-size: 10px;
      font-weight: 500;
      display: flex;
      align-items: center;
    }

    .bline-cat.cat-DARK   { color: var(--cat-DARK); }
    .bline-cat.cat-BLOG   { color: var(--cat-BLOG); }
    .bline-cat.cat-PROJECT { color: var(--cat-PROJECT); }
    .bline-cat.cat-TECH   { color: var(--cat-TECH); }
    .bline-cat.cat-DEVLOG { color: var(--cat-DEVLOG); }

    .bline-date {
      font-size: 10px;
      color: var(--text-muted);
      display: flex;
      align-items: center;
    }

    .bline-title {
      flex: 1;
      color: var(--text);
      padding: 0 12px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      display: flex;
      align-items: center;
    }

    .bline:hover .bline-title { color: var(--text-bright); }
    .bline:hover .bline-date { color: var(--gray); }

    .bline-arrow {
      color: var(--text-muted);
      opacity: 0;
      padding-right: 8px;
      transition: opacity 0.1s;
    }

    .bline:hover .bline-arrow { opacity: 1; }

    /* 鈹€鈹€ Crypto component spacer 鈹€鈹€ */
    .crypto-wrap {
      margin-bottom: 16px;
    }

    /* 鈹€鈹€ Status bar 鈹€鈹€ */
    .statusbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 22px;
      background: var(--border-active);
      padding: 0 8px;
      flex-shrink: 0;
    }

    .sbar-left, .sbar-right {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .sbar-item {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      color: var(--text-bright);
      display: flex;
      align-items: center;
      gap: 4px;
      cursor: default;
    }

    .sbar-item.clickable { cursor: pointer; }
    .sbar-item.clickable:hover { opacity: 0.8; }

    .sbar-branch { color: var(--cyan); font-weight: 700; }
    .sbar-accent { color: var(--accent); }

    /* 鈹€鈹€ Responsive 鈹€鈹€ */
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .activity-bar { display: none; }
      .app { height: auto; min-height: 100vh; }
      .titlebar-title .file { display: none; }
      .code-view { grid-template-columns: 36px 1fr; }
      .bline { grid-template-columns: 36px 50px 1fr; }
      .meta-bar { flex-wrap: wrap; }
      .meta-cell { min-width: 50%; border-bottom: 1px solid var(--border); }
    }
  </style>

