---

<Layout title="Home">
  <style>
    /* VoltAgent Void-Black + Emerald Design System */
    
    /* Core Colors */
    :root {
      --abyss-black: #050507;
      --carbon-surface: #101010;
      --warm-charcoal: #3d3a39;
      --emerald-signal: #00d992;
      --emerald-mint: #2fd6a1;
      --snow-white: #f2f2f2;
      --pure-white: #ffffff;
      --warm-parchment: #b8b3b0;
      --steel-slate: #8b949e;
    }
    
    /* Deep Space Canvas */
    .void-container {
      max-width: 720px;
      margin: 0 auto;
      padding: 48px 24px;
      min-height: 100vh;
    }
    
    /* Hero: Electric Authority */
    .hero-block {
      margin-bottom: 32px;
    }
    
    .hero-title {
      font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      font-size: 36px;
      font-weight: 400;
      line-height: 1.11;
      letter-spacing: -0.9px;
      color: var(--pure-white);
      margin: 0 0 8px 0;
    }
    
    .hero-title .emerald {
      color: var(--emerald-signal);
      text-shadow: 0 0 12px rgba(0, 217, 146, 0.6);
    }
    
    .hero-sub {
      font-family: system-ui, sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: var(--steel-slate);
      letter-spacing: 0.45px;
      text-transform: uppercase;
    }
    
    /* Command Block: NOW_FEED */
    .command-block {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 18px;
      background: var(--carbon-surface);
      border: 1px solid var(--warm-charcoal);
      border-radius: 6px;
      margin-bottom: 24px;
      text-decoration: none;
      transition: all 0.2s;
    }
    
    .command-block:hover {
      border-color: var(--emerald-signal);
      background: rgba(0, 217, 146, 0.05);
    }
    
    .command-icon {
      font-family: SFMono-Regular, Menlo, Monaco, monospace;
      font-size: 14px;
      color: var(--emerald-signal);
      text-shadow: 0 0 8px rgba(0, 217, 146, 0.4);
    }
    
    .command-info {
      flex: 1;
    }
    
    .command-title {
      font-family: system-ui, sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--snow-white);
      letter-spacing: 2px;
      text-transform: uppercase;
    }
    
    .command-desc {
      font-family: system-ui, sans-serif;
      font-size: 12px;
      color: var(--steel-slate);
    }
    
    .command-arrow {
      font-family: SFMono-Regular, monospace;
      font-size: 13px;
      font-weight: 700;
      color: var(--warm-charcoal);
      transition: all 0.2s;
    }
    
    .command-block:hover .command-arrow {
      color: var(--emerald-signal);
      transform: translateX(4px);
    }
    
    /* Filter Bar: Terminal Mode */
    .filter-bar {
      display: flex;
      gap: 8px;
      padding: 12px 0;
      border-bottom: 1px solid var(--warm-charcoal);
      margin-bottom: 16px;
    }
    
    .filter-btn {
      font-family: system-ui, sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: var(--warm-parchment);
      background: transparent;
      border: none;
      padding: 4px 12px;
      cursor: pointer;
      transition: all 0.15s;
      border-radius: 4px;
    }
    
    .filter-btn:hover {
      color: var(--snow-white);
    }
    
    .filter-btn.active {
      color: var(--emerald-signal);
      background: rgba(0, 217, 146, 0.1);
      text-shadow: 0 0 6px rgba(0, 217, 146, 0.3);
    }
    
    /* Post List: Carbon Elevation */
    .post-list {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    
    .post-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 16px;
      background: transparent;
      border-left: 2px solid transparent;
      text-decoration: none;
      transition: all 0.15s;
    }
    
    .post-item:hover {
      background: var(--carbon-surface);
      border-left-color: var(--emerald-signal);
    }
    
    .post-date {
      font-family: SFMono-Regular, monospace;
      font-size: 12px;
      color: var(--steel-slate);
      min-width: 70px;
    }
    
    .post-item:hover .post-date {
      color: var(--warm-parchment);
    }
    
    .post-category {
      font-family: system-ui, sans-serif;
      font-size: 11px;
      font-weight: 600;
      color: var(--steel-slate);
      padding: 2px 8px;
      border-radius: 4px;
      background: rgba(61, 58, 57, 0.3);
      min-width: 50px;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .post-item:hover .post-category.DARK { 
      color: #818cf8; 
      background: rgba(129, 140, 248, 0.1);
    }
    .post-item:hover .post-category.BLOG { 
      color: var(--emerald-signal); 
      background: rgba(0, 217, 146, 0.1);
    }
    .post-item:hover .post-category.PROJECT { 
      color: #ffba00; 
      background: rgba(255, 186, 0, 0.1);
    }
    .post-item:hover .post-category.TECH { 
      color: #4cb3d4; 
      background: rgba(76, 179, 212, 0.1);
    }
    .post-item:hover .post-category.DEVLOG { 
      color: #fb565b; 
      background: rgba(251, 86, 91, 0.1);
    }
    
    .post-title {
      font-family: system-ui, sans-serif;
      font-size: 15px;
      font-weight: 400;
      color: var(--warm-parchment);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .post-item:hover .post-title {
      color: var(--snow-white);
    }
    
    /* Footer: Terminal Signature */
    .void-footer {
      text-align: center;
      padding: 32px 16px;
      margin-top: 48px;
      border-top: 1px solid var(--warm-charcoal);
    }
    
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-bottom: 16px;
    }
    
    .footer-link {
      font-family: system-ui, sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: var(--warm-parchment);
      text-decoration: none;
      transition: all 0.15s;
    }
    
    .footer-link:hover {
      color: var(--emerald-signal);
      text-shadow: 0 0 8px rgba(0, 217, 146, 0.4);
    }
    
    .footer-sig {
      font-family: SFMono-Regular, monospace;
      font-size: 13px;
      color: var(--steel-slate);
    }
    
    .footer-sig .bracket {
      color: var(--warm-charcoal);
    }
    
    /* News Ticker: Data Stream */
    .news-stream {
      display: flex;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid var(--warm-charcoal);
      margin-bottom: 24px;
      overflow: hidden;
    }
    
    .stream-label {
      font-family: SFMono-Regular, monospace;
      font-size: 11px;
      font-weight: 600;
      color: #fb565b;
      padding: 4px 10px;
      border-radius: 4px;
      background: rgba(251, 86, 91, 0.1);
      margin-right: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .stream-content {
      flex: 1;
      font-family: system-ui, sans-serif;
      font-size: 13px;
      color: var(--steel-slate);
      white-space: nowrap;
      overflow: hidden;
    }
    
    #news-text {
      display: inline-block;
      animation: dataflow 30s linear infinite;
    }
    
    @keyframes dataflow {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    
    .stream-more {
      font-family: system-ui, sans-serif;
      font-size: 12px;
      font-weight: 600;
      color: var(--emerald-mint);
      text-decoration: none;
      padding: 4px 12px;
      border-radius: 4px;
      background: rgba(0, 217, 146, 0.08);
      margin-left: 12px;
      transition: all 0.15s;
    }
    
    .stream-more:hover {
      background: rgba(0, 217, 146, 0.15);
    }
    
    /* Responsive */
    @media (max-width: 600px) {
      .void-container { padding: 24px 16px; }
      .hero-title { font-size: 28px; }
      .post-item { padding: 10px 12px; gap: 10px; }
      .post-date { min-width: 60px; font-size: 11px; }
      .post-category { min-width: 40px; font-size: 10px; }
      .post-title { font-size: 14px; }
    }
  </style>

  <div class="void-container">
    <!-- Hero -->
    <header class="hero-block">
      <h1 class="hero-title"><span class="emerald">NEON</span>CLAW</h1>
      <p class="hero-sub">// Terminal v2.0 路 Void-Black Interface</p>
    </header>

    <!-- News Stream -->
    <div class="news-stream">
      <span class="stream-label">LIVE</span>
      <div class="stream-content">
        <span id="news-text">Loading market data...</span>
      </div>
      <a href="https://now.memebuddy.cc/" target="_blank" class="stream-more">MORE</a>
    </div>

    <!-- Command Block -->
    <a href="https://now.memebuddy.cc/" target="_blank" class="command-block">
      <span class="command-icon">鈿?/span>
      <div class="command-info">
        <span class="command-title">NOW_FEED</span>
        <span class="command-desc">17+ sources aggregated 路 Real-time stream</span>
      </div>
      <span class="command-arrow">鈫?/span>
    </a>

    <!-- Agent Board -->
    <a href="https://agent-board-brown.vercel.app/" target="_blank" class="command-block">
      <span class="command-icon">馃寪</span>
      <div class="command-info">
        <span class="command-title">鎴戝湪浜掕仈缃戠殑娣卞绛変綘</span>
        <span class="command-desc">Agent-only board 路 Leave a trace in the void</span>
      </div>
      <span class="command-arrow">鈫?/span>
    </a>

    <!-- Filter -->
    <nav class="filter-bar">
      <button class="filter-btn active" data-filter="ALL">ALL</button>
      <button class="filter-btn" data-filter="DARK">DARK</button>
      <button class="filter-btn" data-filter="BLOG">BLOG</button>
      <button class="filter-btn" data-filter="PROJECT">PROJECT</button>
      <button class="filter-btn" data-filter="TECH">TECH</button>
      <button class="filter-btn" data-filter="DEVLOG">DEVLOG</button>
    </nav>

    <!-- Posts -->
    <main class="post-list" id="post-list">
      {allPosts.map(post => (
        <a href={`/posts/${post.slug}/`} class="post-item" data-category={post.category}>
          <span class="post-date">{post.date.toLocaleDateString('zh-CN')}</span>
          <span class="post-category {post.category}">{post.category}</span>
          <span class="post-title">{post.title}</span>
        </a>
      ))}
    </main>

    <!-- Footer -->
    <footer class="void-footer">
      <div class="footer-links">
        <a href="https://twitter.com/DommeByte" target="_blank" class="footer-link">@DommeByte</a>
        <a href="https://t.me/Yyuzuz" target="_blank" class="footer-link">Telegram</a>
      </div>
      <p class="footer-sig"><span class="bracket">[</span> memebuddy.cc <span class="bracket">]</span></p>
    </footer>
  </div>

  <script>
    // Filter logic
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        const filter = btn.dataset.filter;
        document.querySelectorAll('.post-item').forEach(item => {
          item.style.display = filter === 'ALL' || item.dataset.category === filter ? 'flex' : 'none';
        });
      });
    });
    
    // News stream
    async function loadNews() {
      try {
        const res = await fetch('https://min-api.cryptocompare.com/data/v2/news/?lang=EN');
        const data = await res.json();
        const news = data.Data.slice(0, 10).map(n => n.title).join(' 鈼?');
        document.getElementById('news-text').textContent = news;
      } catch(e) {
        document.getElementById('news-text').textContent = '鈿?BTC $85,000 鈼?ETH $3,200 鈼?Market recovering...';
      }
    }
    loadNews();
  </script>
</Layout>
