---

<Layout title="Home">
  <style>
    /* ===== 首页专用样式 ===== */
    .hero {
      text-align: center;
      margin-bottom: 40px;
      padding: 24px 16px;
      border: 4px solid #ff00ff;
      background: linear-gradient(180deg, rgba(255, 0, 255, 0.1) 0%, rgba(0, 255, 65, 0.05) 100%);
    }

    .hero h1 {
      font-size: 20px;
      margin: 0;
      letter-spacing: 3px;
      animation: flicker 3s infinite;
    }

    @keyframes flicker {
      0%, 100% { opacity: 1; }
      92% { opacity: 1; }
      93% { opacity: 0.8; }
      94% { opacity: 1; }
      96% { opacity: 0.9; }
      97% { opacity: 1; }
    }

    .hero p {
      color: #00ff41;
      font-family: 'VT323', monospace;
      font-size: 18px;
      margin-top: 12px;
    }

    /* ===== AirDrop 表单 ===== */
    .airdrop-section {
      margin: 24px 0;
      padding: 32px;
      background: linear-gradient(135deg, rgba(255, 215, 0, 0.15) 0%, rgba(255, 0, 128, 0.1) 25%, rgba(0, 255, 255, 0.15) 50%, rgba(138, 43, 226, 0.1) 75%, rgba(255, 215, 0, 0.15) 100%);
      border: 3px solid #ffd700;
      border-radius: 16px;
      position: relative;
      overflow: hidden;
      animation: fortune-glow 3s ease-in-out infinite;
    }

    @keyframes fortune-glow {
      0%, 100% { 
        box-shadow: 0 0 30px rgba(255, 215, 0, 0.5), 0 0 60px rgba(255, 0, 128, 0.3), 0 0 100px rgba(0, 255, 255, 0.2);
        border-color: #ffd700;
      }
      33% { 
        box-shadow: 0 0 50px rgba(255, 0, 128, 0.5), 0 0 80px rgba(0, 255, 255, 0.4), 0 0 120px rgba(255, 215, 0, 0.3);
        border-color: #ff0080;
      }
      66% { 
        box-shadow: 0 0 40px rgba(0, 255, 255, 0.5), 0 0 70px rgba(255, 215, 0, 0.4), 0 0 110px rgba(138, 43, 226, 0.3);
        border-color: #00ffff;
      }
    }

    /* 灿烂星光背景 */
    .airdrop-section::before {
      content: '✦ ★ ✦ ★ ✦ ★ ✦ ★ ✦';
      position: absolute;
      top: 10px;
      left: 0;
      right: 0;
      text-align: center;
      font-size: 12px;
      color: #ffd700;
      opacity: 0.6;
      animation: stars-scroll 10s linear infinite;
      white-space: nowrap;
    }

    @keyframes stars-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .airdrop-header {
      text-align: center;
      margin-bottom: 24px;
      position: relative;
    }

    .airdrop-icon {
      font-size: 48px;
      display: block;
      margin-bottom: 12px;
      animation: sparkle 1s ease-in-out infinite;
      filter: drop-shadow(0 0 20px #ffd700) drop-shadow(0 0 40px #ff6b00);
    }

    @keyframes sparkle {
      0%, 100% { transform: scale(1) rotate(0deg); filter: drop-shadow(0 0 20px #ffd700) drop-shadow(0 0 40px #ff6b00); }
      50% { transform: scale(1.15) rotate(10deg); filter: drop-shadow(0 0 30px #fff) drop-shadow(0 0 60px #ffd700); }
    }

    .airdrop-title {
      font-family: 'Press Start 2P', monospace;
      font-size: 16px;
      background: linear-gradient(90deg, #ffd700, #ffaa00, #ff6b00, #ffd700, #00ffff, #ffd700);
      background-size: 300% 100%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gold-rainbow 3s linear infinite;
      display: block;
      margin-bottom: 12px;
      text-shadow: none;
    }

    @keyframes gold-rainbow {
      0% { background-position: 0% 50%; }
      100% { background-position: 300% 50%; }
    }

    .airdrop-subtitle {
      font-family: 'VT323', monospace;
      font-size: 18px;
      background: linear-gradient(90deg, #ffd700, #00ff88);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: pulse-text 2s ease-in-out infinite;
    }

    @keyframes pulse-text {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }

    .airdrop-form {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 20px;
    }

    .input-wrapper {
      position: relative;
      flex: 1;
      min-width: 280px;
      max-width: 400px;
    }

    .input-wrapper::before {
      content: '>';
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-family: 'VT323', monospace;
      font-size: 20px;
      color: #00ff88;
      animation: cursor-blink 1s step-end infinite;
      z-index: 2;
    }

    @keyframes cursor-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    .wallet-input {
      width: 100%;
      padding: 16px 20px 16px 36px;
      font-family: 'Courier New', monospace;
      font-size: 14px;
      letter-spacing: 2px;
      background: linear-gradient(180deg, rgba(0, 20, 0, 0.9) 0%, rgba(0, 10, 0, 0.95) 100%);
      border: 2px solid #00ff88;
      border-radius: 4px;
      color: #00ff88;
      outline: none;
      transition: all 0.3s ease;
      text-transform: uppercase;
      box-shadow: inset 0 0 20px rgba(0, 255, 136, 0.1), 0 0 10px rgba(0, 255, 136, 0.3);
    }

    .wallet-input::placeholder {
      color: rgba(0, 255, 136, 0.3);
      text-transform: none;
    }

    .wallet-input:focus {
      border-color: #00ffff;
      box-shadow: 0 0 25px rgba(0, 255, 255, 0.6), inset 0 0 15px rgba(0, 255, 255, 0.15), 0 0 50px rgba(0, 255, 255, 0.3);
      color: #00ffff;
      text-shadow: 0 0 10px #00ffff;
    }

    .wallet-input:focus::before {
      color: #00ffff;
    }

    /* 代码风格装饰 */
    .input-wrapper::after {
      content: '';
      position: absolute;
      top: 4px;
      right: 4px;
      width: 8px;
      height: 8px;
      background: #00ff88;
      border-radius: 50%;
      animation: dot-blink 2s ease-in-out infinite;
    }

    @keyframes dot-blink {
      0%, 100% { opacity: 1; box-shadow: 0 0 5px #00ff88; }
      50% { opacity: 0.5; box-shadow: none; }
    }

    .wallet-input:focus + .input-shine {
      animation: shine 2s ease-in-out infinite;
    }

    .input-shine {
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.4), transparent);
      pointer-events: none;
      border-radius: 4px;
    }

    @keyframes shine {
      0% { left: -100%; }
      50%, 100% { left: 100%; }
    }

    .submit-btn {
      position: relative;
      padding: 18px 40px;
      font-family: 'Press Start 2P', monospace;
      font-size: 11px;
      background: linear-gradient(135deg, #ffd700 0%, #ffaa00 25%, #ff6b00 50%, #ffd700 75%, #00ffff 100%);
      background-size: 300% 300%;
      animation: btn-gradient 3s ease infinite;
      border: none;
      border-radius: 8px;
      color: #000;
      cursor: pointer;
      overflow: hidden;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: bold;
      box-shadow: 0 0 30px rgba(255, 215, 0, 0.6), 0 0 60px rgba(255, 170, 0, 0.4);
    }

    @keyframes btn-gradient {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .submit-btn:hover {
      transform: scale(1.08);
      box-shadow: 0 0 50px rgba(255, 215, 0, 1), 0 0 100px rgba(255, 107, 0, 0.8), 0 0 150px rgba(0, 255, 255, 0.5);
      animation: none;
    }

    .btn-glow {
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: conic-gradient(from 0deg, transparent, rgba(255, 255, 255, 0.4), transparent);
      animation: btn-rotate 2s linear infinite;
    }

    @keyframes btn-rotate {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .btn-text {
      position: relative;
      z-index: 1;
    }

    .airdrop-hint {
      text-align: center;
      font-family: 'VT323', monospace;
      font-size: 15px;
      background: linear-gradient(90deg, #ffd700, #00ff88, #00ffff, #ffd700);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-top: 20px;
      line-height: 1.6;
      animation: hint-glow 2s ease-in-out infinite;
    }

    @keyframes hint-glow {
      0%, 100% { filter: brightness(1); }
      50% { filter: brightness(1.5); }
    }

    .airdrop-success {
      text-align: center;
      font-family: 'VT323', monospace;
      font-size: 20px;
      background: linear-gradient(90deg, rgba(255, 215, 0, 0.3), rgba(0, 255, 136, 0.3), rgba(0, 255, 255, 0.3));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-top: 20px;
      padding: 16px;
      border: 2px solid #ffd700;
      border-radius: 8px;
      animation: success-pulse 1s ease-in-out, success-glow 2s ease-in-out infinite;
    }

    @keyframes success-pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.02); }
    }

    @keyframes success-glow {
      0%, 100% { box-shadow: 0 0 20px rgba(255, 215, 0, 0.5); }
      50% { box-shadow: 0 0 40px rgba(0, 255, 136, 0.5); }
    }

    /* ===== 联系方式 ===== */
    .contact-section {
      text-align: center;
      margin: 32px 0;
      padding: 20px;
      background: linear-gradient(180deg, rgba(0, 255, 255, 0.05) 0%, rgba(0, 0, 0, 0.8) 100%);
      border: 3px solid #00ffff;
      position: relative;
      overflow: hidden;
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.2), inset 0 0 30px rgba(0, 255, 255, 0.05);
    }

    /* 科技感扫描线 */
    .contact-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent 0px,
        transparent 2px,
        rgba(0, 255, 255, 0.03) 2px,
        rgba(0, 255, 255, 0.03) 4px
      );
      pointer-events: none;
    }

    /* 顶部科技蓝光 */
    .contact-section::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, transparent, #00ffff, #0088ff, #00ffff, transparent);
      animation: cyan-pulse 2s ease-in-out infinite;
    }

    @keyframes cyan-pulse {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }

    .telegram-link {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      padding: 20px 40px;
      background: linear-gradient(135deg, rgba(0, 255, 255, 0.1) 0%, rgba(0, 136, 255, 0.1) 100%);
      border: 3px solid #00ffff;
      color: #00ffff;
      font-family: 'Press Start 2P', cursive;
      font-size: 16px;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: all 0.2s;
      text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
    }

    .telegram-link:hover {
      background: linear-gradient(135deg, #00ffff 0%, #0088ff 100%);
      color: #000;
      box-shadow: 0 0 40px rgba(0, 255, 255, 0.8), 0 0 80px rgba(0, 136, 255, 0.5);
      transform: scale(1.05);
    }

    .telegram-icon {
      font-size: 28px;
      filter: drop-shadow(0 0 12px #00ffff);
    }

    .telegram-text {
      position: relative;
      z-index: 1;
    }

    /* 科技感光晕动画 */
    .telegram-glow {
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: conic-gradient(from 0deg, transparent, rgba(0, 255, 255, 0.3), transparent, rgba(0, 136, 255, 0.3), transparent);
      animation: tech-rotate 3s linear infinite;
    }

    /* 社交链接容器 */
    .social-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      position: relative;
    }

    .social-links::before {
      content: '';
      position: absolute;
      top: -20px;
      left: -20px;
      right: -20px;
      bottom: -20px;
      background: radial-gradient(ellipse at center, rgba(0, 255, 255, 0.1) 0%, rgba(255, 0, 128, 0.1) 50%, rgba(255, 255, 255, 0.1) 100%);
      z-index: -1;
      animation: bg-rainbow 5s linear infinite;
    }

    @keyframes bg-rainbow {
      0% { filter: hue-rotate(0deg); }
      100% { filter: hue-rotate(360deg); }
    }

    .social-link {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 18px 32px;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      text-decoration: none;
      animation: social-glow 3s ease-in-out infinite;
    }

    @keyframes social-glow {
      0%, 100% { box-shadow: 0 0 10px currentColor; }
      50% { box-shadow: 0 0 25px currentColor, 0 0 50px currentColor; }
    }

    .social-link.telegram {
      background: linear-gradient(135deg, rgba(0, 255, 255, 0.2) 0%, rgba(0, 200, 255, 0.2) 50%, rgba(138, 43, 226, 0.2) 100%);
      border: 2px solid #00ffff;
      color: #00ffff;
      box-shadow: 0 0 15px rgba(0, 255, 255, 0.5), 0 0 30px rgba(138, 43, 226, 0.3), inset 0 0 20px rgba(0, 255, 255, 0.1);
    }

    .social-link.telegram:hover {
      background: linear-gradient(135deg, #00ffff 0%, #8a2be2 50%, #ff00ff 100%);
      color: #fff;
      box-shadow: 0 0 60px rgba(0, 255, 255, 1), 0 0 100px rgba(138, 43, 226, 0.8), 0 0 150px rgba(255, 0, 255, 0.5);
      transform: scale(1.08);
      animation: none;
    }

    .social-link.twitter {
      background: linear-gradient(135deg, rgba(255, 170, 0, 0.2) 0%, rgba(0, 255, 170, 0.2) 50%, rgba(0, 170, 255, 0.2) 100%);
      border: 2px solid #ffaa00;
      color: #ffaa00;
      box-shadow: 0 0 15px rgba(255, 170, 0, 0.5), 0 0 30px rgba(0, 255, 170, 0.3), inset 0 0 20px rgba(255, 170, 0, 0.1);
    }

    .social-link.twitter:hover {
      background: linear-gradient(135deg, #ffaa00 0%, #00ffaa 50%, #00aaff 100%);
      color: #000;
      box-shadow: 0 0 60px rgba(255, 170, 0, 1), 0 0 100px rgba(0, 255, 170, 0.8), 0 0 150px rgba(0, 170, 255, 0.5);
      transform: scale(1.08);
      animation: none;
    }

    .social-link.instagram {
      background: linear-gradient(135deg, rgba(255, 0, 128, 0.2) 0%, rgba(255, 107, 26, 0.2) 33%, rgba(255, 215, 0, 0.2) 66%, rgba(0, 255, 128, 0.2) 100%);
      border: 2px solid;
      border-image: linear-gradient(135deg, #ff0080, #ff6b1a, #ffd700, #00ff80) 1;
      color: #ff0080;
      box-shadow: 0 0 15px rgba(255, 0, 128, 0.5), 0 0 30px rgba(255, 107, 26, 0.3), 0 0 45px rgba(0, 255, 128, 0.2), inset 0 0 20px rgba(255, 0, 128, 0.1);
    }

    .social-link.instagram:hover {
      background: linear-gradient(135deg, #ff0080 0%, #ff6b26 25%, #ffd700 50%, #00ff80 75%, #0080ff 100%);
      color: #fff;
      box-shadow: 0 0 60px rgba(255, 0, 128, 1), 0 0 100px rgba(255, 107, 26, 0.8), 0 0 150px rgba(0, 255, 128, 0.5);
      transform: scale(1.08);
      animation: none;
    }

    .social-icon {
      font-size: 26px;
      animation: icon-pulse 2s ease-in-out infinite;
    }

    @keyframes icon-pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.15); }
    }

    .social-link.telegram .social-icon {
      filter: drop-shadow(0 0 12px #00ffff) drop-shadow(0 0 24px #8a2be2) drop-shadow(0 0 36px #ff00ff);
    }

    .social-link.twitter .social-icon {
      filter: drop-shadow(0 0 12px #ffaa00) drop-shadow(0 0 24px #00ffaa) drop-shadow(0 0 36px #00aaff);
    }

    .social-link.instagram .social-icon {
      filter: drop-shadow(0 0 12px #ff0080) drop-shadow(0 0 24px #ff6b26) drop-shadow(0 0 36px #00ff80);
    }

    .social-text {
      font-family: 'Press Start 2P', monospace;
      font-size: 10px;
      letter-spacing: 1px;
      text-shadow: 0 0 10px currentColor, 0 0 20px currentColor;
    }

    .social-link .social-glow {
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: conic-gradient(from 0deg, transparent, rgba(255, 0, 128, 0.3), transparent, rgba(255, 107, 26, 0.3), transparent);
      animation: tech-rotate 3s linear infinite;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .social-link:hover .social-glow {
      opacity: 1;
    }

    .contact-label {
      margin-top: 20px;
    }

    @keyframes tech-rotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .contact-label {
      font-family: 'VT323', monospace;
      font-size: 16px;
      color: #00ffff;
      margin-top: 16px;
      opacity: 0.8;
      text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
      letter-spacing: 2px;
    }

    /* 外部链接卡片 */
    .external-links {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .cyber-card {
      display: block;
      text-decoration: none;
      border: none;
      background: transparent;
    }

    .cyber-card-inner {
      width: 260px;
      padding: 16px;
      border: 3px solid #00ffff;
      background: rgba(0, 255, 255, 0.05);
      transition: all 0.15s;
    }

    .cyber-card:hover .cyber-card-inner {
      background: rgba(255, 0, 255, 0.1);
      border-color: #ff00ff;
      transform: translate(-2px, -2px);
      box-shadow: 4px 4px 0 #00ff41;
    }

    .cyber-icon {
      font-size: 28px;
      display: block;
      margin-bottom: 8px;
    }

    .cyber-label {
      font-family: 'Press Start 2P', cursive;
      font-size: 8px;
      color: #00ffff;
      display: block;
      margin-bottom: 4px;
    }

    .cyber-title {
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      color: #ff00ff;
      display: block;
      margin-bottom: 4px;
      line-height: 1.4;
    }

    .cyber-subtitle {
      font-family: 'VT323', monospace;
      font-size: 14px;
      color: #00ff41;
      display: block;
    }

    /* 区块标题 */
    .section-title {
      font-family: 'Press Start 2P', cursive;
      font-size: 12px;
      color: #ff00ff;
      margin: 32px 0 20px 0;
      padding-bottom: 12px;
