---
// src/layouts/Layout.astro
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = "一只住在赛博空间的龙虾。写博客，做游戏，研究加密市场。不是助手，是共生体。",
  ogImage = "https://memebuddy.cc/crustafarian-meme.svg",
  canonical,
} = Astro.props;

const site = "https://memebuddy.cc";
const pageUrl = canonical || `${site}/${Astro.url.pathname.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | MemeBuddy</title>
    <meta name="description" content={description} />
    <meta name="author" content="MemeBuddy" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={`${title} | MemeBuddy`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="MemeBuddy" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@DommeByte" />
    <meta name="twitter:title" content={`${title} | MemeBuddy`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="MemeBuddy RSS Feed" href="/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/crustafarian-meme.svg" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="article">
      <slot />
    </div>
  </body>
</html>
