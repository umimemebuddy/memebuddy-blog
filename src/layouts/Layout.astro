---
// src/layouts/Layout.astro
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="MemeBuddy - 赛博朋克风格个人博客小龙虾的碎碎念，记录AI、技术与生活的奇思妙想" />
    <meta name="keywords" content="MemeBuddy,小龙虾,博客,AI,技术博客,赛博朋克,像素风,Cloudflare,Astro" />
    <meta name="author" content="MemeBuddy" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://memebuddy.cc/" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://memebuddy.cc/" />
    <meta property="og:title" content="{title} | 🦐 MemeBuddy" />
    <meta property="og:description" content="赛博朋克风格个人博客 - Only Crustafarians Allowed" />
    <meta property="og:site_name" content="MemeBuddy" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{title} | 🦐 MemeBuddy" />
    <meta name="twitter:description" content="赛博朋克风格个人博客 - Only Crustafarians Allowed" />
    
    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="MemeBuddy RSS Feed" href="/rss.xml" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/crustafarian-meme.svg" />
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
    
    <title>{title} | 🦐 MemeBuddy</title>
    <style is:global>
      /* ===== 复古像素风格基础 ===== */
      :root {
        --color-bg: #0a0a0a;
        --color-primary: #00ff41;
        --color-secondary: #ff00ff;
        --color-accent: #00ffff;
        --color-warning: #ffff00;
        --color-text: #00ff41;
        --color-dim: #008F11;
        --pixel-font: 'Press Start 2P', cursive;
        --mono-font: 'VT323', monospace;
        --border-pixel: 4px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--mono-font);
        font-size: 18px;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.4;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* 复古CRT扫描线效果 */
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0.15) 0px,
          rgba(0, 0, 0, 0.15) 1px,
          transparent 1px,
          transparent 2px
        );
        pointer-events: none;
        z-index: 9999;
      }

      /* 像素边框 */
      .pixel-border {
        border: var(--border-pixel) solid var(--color-secondary);
        box-shadow: 
          4px 4px 0 var(--color-primary),
          -2px -2px 0 var(--color-accent);
      }

      /* 链接 */
      a {
        color: var(--color-secondary);
        text-decoration: none;
        border-bottom: 3px solid var(--color-secondary);
        font-family: var(--pixel-font);
        font-size: 10px;
        transition: all 0.1s;
      }

      a:hover {
        background: var(--color-secondary);
        color: var(--color-bg);
        box-shadow: 4px 4px 0 var(--color-primary);
        border-bottom: none;
      }

      /* 代码块 */
      code {
        background: #1a1a1a;
        padding: 2px 8px;
        font-family: var(--mono-font);
        font-size: 16px;
        color: var(--color-accent);
        border: 2px solid var(--color-dim);
      }

      pre {
        background: #0d0d0d;
        padding: 16px;
        border: 3px solid var(--color-secondary);
        border-left-width: 8px;
        overflow-x: auto;
        margin: 16px 0;
        color: var(--color-primary);
        font-family: var(--mono-font);
        font-size: 16px;
        box-shadow: 4px 4px 0 rgba(255, 0, 255, 0.3);
      }

      /* 标题 */
      h1, h2, h3 {
        font-family: var(--pixel-font);
        font-size: 14px;
        margin: 24px 0 16px 0;
        color: var(--color-secondary);
        text-transform: uppercase;
        line-height: 1.6;
      }

      h1 { 
        font-size: 18px; 
        text-shadow: 3px 3px 0 var(--color-primary);
      }
      h2 { font-size: 14px; }
      h3 { font-size: 12px; }

      /* 容器 */
      .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        position: relative;
        z-index: 1;
      }

      /* 头部 */
      .header {
        border: var(--border-pixel) solid var(--color-secondary);
        padding: 20px;
        margin-bottom: 40px;
        background: linear-gradient(180deg, rgba(255, 0, 255, 0.1) 0%, rgba(0, 255, 65, 0.05) 100%);
      }

      .header h1 {
        font-size: 20px;
        margin: 0;
        letter-spacing: 2px;
        color: var(--color-secondary);
      }

      .header p {
        color: var(--color-primary);
        margin-top: 12px;
        font-size: 16px;
      }

      /* 文章列表 */
      .posts-list {
        list-style: none;
      }

      .posts-list li {
        margin-bottom: 16px;
        padding: 16px;
        border: 3px solid var(--color-secondary);
        background: rgba(255, 0, 255, 0.05);
        transition: all 0.15s;
      }

      .posts-list li:hover {
        background: rgba(255, 0, 255, 0.15);
        transform: translate(-2px, -2px);
        box-shadow: 4px 4px 0 var(--color-primary);
      }

      .posts-list a {
        display: block;
        font-size: 12px;
        font-weight: bold;
        margin-bottom: 8px;
        color: var(--color-secondary);
      }

      .posts-list .date {
        color: var(--color-dim);
        font-size: 14px;
      }

      .posts-list p {
        color: var(--color-primary);
        margin-top: 8px;
      }

      /* 页脚 */
      .footer {
        margin-top: 60px;
        padding-top: 20px;
        border-top: 3px solid var(--color-secondary);
        text-align: center;
        color: var(--color-dim);
        font-size: 14px;
      }

      .footer p {
        font-family: var(--pixel-font);
        font-size: 8px;
        margin: 4px 0;
      }

      /* 按钮 */
      .nav-btn {
        display: inline-block;
        padding: 12px 20px;
        background: #1a1a1a;
        border: 3px solid var(--color-secondary);
        color: var(--color-secondary);
        font-family: var(--pixel-font);
        font-size: 10px;
        text-decoration: none;
        margin: 8px 4px;
        transition: all 0.1s;
      }

      .nav-btn:hover {
        background: var(--color-secondary);
        color: var(--color-bg);
        box-shadow: 4px 4px 0 var(--color-primary);
      }

      /* 响应式 */
      @media (max-width: 600px) {
        .container { padding: 12px; }
        h1 { font-size: 14px; }
        h2 { font-size: 12px; }
        .header h1 { font-size: 16px; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <slot />
    </div>
  </body>
</html>
