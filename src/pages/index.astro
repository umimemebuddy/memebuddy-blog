  <script>
    // Filter
    document.querySelectorAll('.fbtn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const f = btn.dataset.filter;
        const status = document.getElementById('filter-status');
        if (status) status.textContent = '○ ' + f;
        document.querySelectorAll('.bline').forEach(line => {
          line.style.display = (f === 'ALL' || line.dataset.category === f) ? 'grid' : 'none';
        });
      });
    });

    // News
    (async () => {
      try {
        const res = await fetch('https://min-api.cryptocompare.com/data/v2/news/?lang=EN');
        const data = await res.json();
        const head = data.Data?.[0]?.title;
        const el = document.getElementById('news-headline');
        if (el && head) el.textContent = head.length > 30 ? head.slice(0, 30) + '...' : head;
      } catch {}
    })();
  </script>
