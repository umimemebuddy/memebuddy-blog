<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

< Layout title="Home">
<style>
  :root {
    --bg: #050505;
    --surface: #0a0a0a;
    --border: #1a1a1a;
    --border-strong: #262626;
    --text: #e0e0e0;
    --text-dim: #666;
    --text-muted: #333;
    --accent: #00ff41;
    --accent-dim: rgba(0, 255, 65, 0.06);
    --cat-DARK: #e0e0e0;
    --cat-BLOG: #00ff41;
    --cat-PROJECT: #ffd700;
    --cat-TECH: #00b4d8;
    --cat-DEVLOG: #ff6b6b;
  }

  .article { max-width: 100% !important; padding: 0 !important; }
  body { background: var(--bg) !important; }
  body::before { display: none !important; }

  /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
     LAYOUT
     鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
  .wrap {
    max-width: 800px;
    margin: 0 auto;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    min-height: 100vh;
    background: var(--bg);
  }

  .inner {
    padding: 48px 40px;
  }

  /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
     HEADER
     鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
  .header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 24px;
    padding-bottom: 32px;
    margin-bottom: 0;
    border-bottom: 1px solid var(--border);
  }

  .brand-mark {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .brand-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 40px;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -1px;
    line-height: 1;
    margin-bottom: 10px;
  }

  .brand-title em {
    font-style: normal;
    color: var(--accent);
  }

  .brand-desc {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .brand-meta {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
    margin-top: 12px;
    letter-spacing: 1px;
  }

  /* Quick links - right column */
  .quick-links {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 160px;
  }

  .qlink {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border: 1px solid var(--border);
    text-decoration: none;
    transition: border-color 0.1s, background 0.1s;
    background: var(--surface);
  }

  .qlink:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  .qlink-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .qlink-desc {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    color: var(--text-dim);
  }

  .qlink-arrow {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    transition: transform 0.1s, color 0.1s;
  }

  .qlink:hover .qlink-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
     CRYPTO
     鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
  .crypto-wrap {
    margin: 0;
    border-bottom: 1px solid var(--border);
  }

  /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
     FILTER
     鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
  .filter {
    display: flex;
    border-bottom: 1px solid var(--border-strong);
  }

  .fbtn {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--text-muted);
    background: transparent;
    border: none;
    border-right: 1px solid var(--border-strong);
    padding: 12px 16px;
    cursor: pointer;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.1s, background 0.1s;
  }

  .fbtn:last-child { border-right: none; }

  .fbtn:hover {
    color: var(--text);
    background: var(--surface);
  }

  .fbtn.on {
    color: var(--accent);
    background: var(--accent-dim);
    border-bottom: 1px solid var(--accent);
    margin-bottom: -1px;
  }

  /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
     POST LIST
     鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
  .post-list {
    border-bottom: 1px solid var(--border);
  }

  .prow {
    display: grid;
    grid-template-columns: 72px 52px 1fr;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.1s;
  }

  .prow:last-child { border-bottom: none; }
  .prow:hover { background: var(--surface); }

  .pdate {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    padding: 0 12px;
    border-right: 1px solid var(--border);
  }

  .prow:hover .pdate { color: var(--text-dim); }

  .pcat {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    padding: 0 10px;
    border-right: 1px solid var(--border);
    letter-spacing: 0.5px;
  }

  .pcat.D { color: var(--cat-DARK); }
  .pcat.B { color: var(--cat-BLOG); }
  .pcat.P { color: var(--cat-PROJECT); }
  .pcat.T { color: var(--cat-TECH); }
  .pcat.G { color: var(--cat-DEVLOG); }

  .ptitle {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    padding: 0 14px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .prow:hover .ptitle {
    color: var(--text);
  }

  /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
     FOOTER
     鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
  }

  .flinks {
    display: flex;
    gap: 20px;
  }

  .flink {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.1s;
  }

  .flink:hover { color: var(--text); }
  .flink.dim { opacity: 0.4; }
  .flink.dim:hover { opacity: 1; }

  .fsig {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 1px;
  }

  /* 鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?
     RESPONSIVE
     鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺?*/
  @media (max-width: 640px) {
    .inner { padding: 24px 16px; }
    .header { grid-template-columns: 1fr; }
    .quick-links { min-width: unset; }
    .prow { grid-template-columns: 60px 44px 1fr; }
    .ptitle { font-size: 13px; }
    .footer { flex-direction: column; gap: 16px; align-items: flex-start; }
  }
</style>

