---
import Layout from '../layouts/Layout.astro';

const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ');
---

<Layout title="Knowledge Base" description="龙虾的记忆仓库 · 搜索 560+ 条个人知识记录" canonical="/kb/">
<style>
  :root {
    --bg: #ffffff;
    --bd: #e5e5e5;
    --tx: #111111;
    --tx2: #666666;
    --tx3: #cccccc;
    --ac: #000000;
  }
  body::before { display: none !important; }
  .a { max-width: 820px; margin: 0 auto; min-height: 100vh; border-left: 1px solid var(--bd); border-right: 1px solid var(--bd); }
  .top-bar { display: flex; align-items: center; justify-content: space-between; padding: 10px 28px; border-bottom: 1px solid var(--bd); }
  .top-logo { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx3); letter-spacing: 3px; text-decoration: none; }
  .top-logo:hover { color: var(--tx2); }
  .top-back { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx3); text-decoration: none; letter-spacing: 1px; }
  .top-back:hover { color: var(--tx); }
  .top-time { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx3); }

  .hero {
    padding: 52px 28px 36px;
    border-bottom: 1px solid var(--bd);
  }
  .hero-label {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    color: var(--tx3);
    letter-spacing: 3px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-label::before {
    content: '';
    display: inline-block;
    width: 16px;
    height: 1px;
    background: var(--ac);
  }
  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 36px;
    font-weight: 300;
    color: var(--tx);
    letter-spacing: -1px;
    margin-bottom: 8px;
    line-height: 1.1;
  }
  .hero-title em { font-style: normal; color: var(--ac); }
  .hero-sub {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: var(--tx2);
    line-height: 1.5;
    margin-bottom: 28px;
  }

  .search-box {
    display: flex;
    border: 1px solid var(--bd);
    transition: border-color .15s;
  }
  .search-box:focus-within { border-color: var(--ac); }
  .search-icon {
    display: flex;
    align-items: center;
    padding: 0 14px;
    color: var(--tx3);
    font-size: 14px;
    flex-shrink: 0;
  }
  #search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    color: var(--tx);
    padding: 14px 0;
    caret-color: var(--ac);
  }
  #search-input::placeholder { color: var(--tx3); }
  .search-clear {
    display: none;
    align-items: center;
    padding: 0 14px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--tx3);
    font-size: 14px;
    font-family: 'Space Mono', monospace;
    transition: color .1s;
  }
  .search-clear:hover { color: var(--tx); }
  .search-clear.show { display: flex; }

  .filters {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--bd);
    overflow-x: auto;
  }
  .filter-btn {
    flex-shrink: 0;
    padding: 10px 16px;
    border: none;
    border-right: 1px solid var(--bd);
    background: transparent;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--tx3);
    cursor: pointer;
    letter-spacing: 1px;
    transition: color .1s, background .1s;
  }
  .filter-btn:hover { color: var(--tx2); background: #fafafa; }
  .filter-btn.active { color: var(--ac); background: #f0f0f0; }
  .filter-btn:last-child { border-right: none; }
  .filter-count {
    font-size: 8px;
    margin-left: 4px;
    opacity: 0.6;
  }

  .results-area {
    padding: 24px 28px 40px;
    min-height: 300px;
  }

  .results-meta {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--tx3);
    margin-bottom: 18px;
    letter-spacing: 0.5px;
  }
  .results-meta span { color: var(--tx2); }

  .result-card {
    display: block;
    padding: 18px 0;
    border-bottom: 1px solid var(--bd);
    text-decoration: none;
    transition: background .1s;
    cursor: pointer;
  }
  .result-card:last-child { border-bottom: none; }
  .result-card:hover { background: #fafafa; margin: 0 -28px; padding-left: 28px; padding-right: 28px; }
  .result-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 7px;
  }
  .result-cat {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    color: var(--tx3);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .result-date {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    color: var(--tx3);
  }
  .result-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--tx);
    margin-bottom: 6px;
    line-height: 1.4;
  }
  .result-snippet {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    color: var(--tx2);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .result-snippet mark {
    background: rgba(255, 230, 0, 0.35);
    color: var(--tx);
    padding: 0 2px;
    border-radius: 2px;
  }
  .result-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .result-tag {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    color: var(--tx3);
    padding: 2px 6px;
    border: 1px solid var(--bd);
    letter-spacing: 0.5px;
  }

  .empty-state {
    text-align: center;
    padding: 80px 0;
  }
  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
    opacity: 0.15;
  }
  .empty-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 300;
    color: var(--tx);
    margin-bottom: 8px;
  }
  .empty-sub {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--tx3);
    line-height: 1.6;
  }

  .loading {
    padding: 40px 0;
    text-align: center;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--tx3);
    letter-spacing: 2px;
  }
  .loading::after {
    content: '...';
    animation: blink 1.2s steps(3, end) infinite;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

  .hint-state {
    padding: 32px 0;
  }
  .hint-title {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    color: var(--tx3);
    letter-spacing: 2px;
    margin-bottom: 14px;
  }
  .hint-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .hint-chip {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--tx2);
    padding: 5px 10px;
    border: 1px solid var(--bd);
    cursor: pointer;
    background: transparent;
    transition: border-color .1s, color .1s;
    letter-spacing: 0.5px;
  }
  .hint-chip:hover { border-color: var(--ac); color: var(--ac); }

  .bottom-bar {
    border-top: 1px solid var(--bd);
    padding: 14px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .bottom-link {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--tx3);
    text-decoration: none;
    letter-spacing: 1px;
    transition: color .1s;
  }
  .bottom-link:hover { color: var(--tx); }
  .bottom-meta {
    font-family: 'Space Mono', monospace;
    font-size: 8px;
    color: var(--tx3);
    letter-spacing: 1px;
  }

  @media (max-width: 640px) {
    .a { border: none; }
    .hero { padding: 32px 16px 24px; }
    .hero-title { font-size: 26px; }
    .results-area { padding: 20px 16px 32px; }
    .result-card:hover { margin: 0 -16px; padding-left: 16px; padding-right: 16px; }
    .bottom-bar { padding: 12px 16px; }
  }
</style>

<div class="a">
  <div class="top-bar">
    <a href="/" class="top-logo">MEMEBUDDY.CC</a>
    <a href="/" class="top-back">&lt;- Back</a>
    <span class="top-time">// {buildTime}</span>
  </div>

  <div class="hero">
    <div class="hero-label">KNOWLEDGE BASE</div>
    <h1 class="hero-title">龙虾的<em>记忆仓库</em></h1>
    <p class="hero-sub"><span id="hero-count">--</span> 条记忆 · 全局搜索 · FTS5 加速</p>

    <div class="search-box">
      <div class="search-icon">⌕</div>
      <input
        id="search-input"
        type="text"
        placeholder="搜索记忆、概念、关键词..."
        autocomplete="off"
        spellcheck="false"
      />
      <button class="search-clear" id="clear-btn" title="清除">×</button>
    </div>
  </div>

  <div class="filters" id="filters">
    <button class="filter-btn active" data-cat="ALL">ALL<span class="filter-count" id="count-all">--</span></button>
  </div>

  <div class="results-area" id="results-area">
    <div class="hint-state" id="hint-state">
      <div class="hint-title">试试搜这些：</div>
      <div class="hint-grid">
        <button class="hint-chip" data-q="SOUL">SOUL.md</button>
        <button class="hint-chip" data-q="lobster">龙虾</button>
        <button class="hint-chip" data-q="market">市场</button>
        <button class="hint-chip" data-q="system">系统</button>
        <button class="hint-chip" data-q="2026">2026</button>
        <button class="hint-chip" data-q="memory">记忆</button>
      </div>
    </div>
  </div>

  <div class="bottom-bar">
    <a href="/" class="bottom-link">MEMEBUDDY.CC</a>
    <span class="bottom-meta">nini-kb · D1 + FTS5</span>
  </div>
</div>

<script>
  const API = 'https://nini-kb.umimemebuddy.workers.dev';
  const input = document.getElementById('search-input');
  const clearBtn = document.getElementById('clear-btn');
  const resultsArea = document.getElementById('results-area');
  const filtersEl = document.getElementById('filters');
  const hintState = document.getElementById('hint-state');
  const countAll = document.getElementById('count-all');

  let currentCat = 'ALL';
  let currentResults = [];
  let debounceTimer = null;

  // Fetch stats on load
  (async () => {
    try {
      const r = await fetch(`${API}/api/stats`);
      const d = await r.json();
      countAll.textContent = d.doc_count || '--';
      document.getElementById('hero-count').textContent = d.doc_count || '--';
      if (d.categories) {
        const cats = [
          { cat: 'ALL', label: 'ALL' },
          ...d.categories.slice(0, 8).map(c => ({ cat: c.category, label: c.category })),
        ];
        filtersEl.innerHTML = cats.map(c => `
          <button class="filter-btn${c.cat === 'ALL' ? ' active' : ''}" data-cat="${c.cat}">
            ${c.label}<span class="filter-count">${c.cat === 'ALL' ? '' : c.cat === 'ALL' ? '' : ''}</span>
          </button>
        `).join('');
        // Add counts
        document.querySelectorAll('.filter-btn').forEach(b => {
          const cat = b.dataset.cat;
          if (cat !== 'ALL') {
            const found = d.categories.find(c => c.category === cat);
            if (found) b.innerHTML = `${found.category}<span class="filter-count">${found.cnt}</span>`;
          }
        });
        // Reattach filter listeners
        filtersEl.querySelectorAll('.filter-btn').forEach(b => b.addEventListener('click', handleFilterClick));
      }
    } catch(e) {
      console.warn('stats fetch failed', e);
    }
  })();

  input.addEventListener('input', () => {
    clearBtn.classList.toggle('show', input.value.length > 0);
    clearBtn.style.display = input.value ? 'flex' : 'none';
    debounceSearch();
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.classList.remove('show');
    clearBtn.style.display = 'none';
    showHint();
    input.focus();
  });

  document.querySelectorAll('.hint-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.q;
      clearBtn.style.display = 'flex';
      doSearch(btn.dataset.q);
    });
  });

  function debounceSearch() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const q = input.value.trim();
      if (q.length >= 1) doSearch(q);
      else showHint();
    }, 300);
  }

  function handleFilterClick() {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    currentCat = this.dataset.cat;
    renderResults();
  }
  filtersEl.querySelectorAll('.filter-btn').forEach(b => b.addEventListener('click', handleFilterClick));

  async function doSearch(q) {
    hintState.style.display = 'none';
    resultsArea.innerHTML = '<div class="loading">SEARCHING</div>';
    try {
      const r = await fetch(`${API}/api/search?q=${encodeURIComponent(q)}`);
      const d = await r.json();
      currentResults = d.results || [];
      renderResults();
    } catch(e) {
      resultsArea.innerHTML = '<div class="empty-state"><div class="empty-icon">⚡</div><div class="empty-title">网络错误</div><div class="empty-sub">无法连接知识库 API</div></div>';
    }
  }

  function renderResults() {
    const filtered = currentCat === 'ALL'
      ? currentResults
      : currentResults.filter(r => r.category === currentCat);

    if (filtered.length === 0) {
      resultsArea.innerHTML = `
        <div class="empty-state">
          <div class="empty-icon">○</div>
          <div class="empty-title">没有找到</div>
          <div class="empty-sub">试试更通用的关键词</div>
        </div>`;
      return;
    }

    resultsArea.innerHTML = `
      <div class="results-meta">
        找到 <span>${filtered.length}</span> 条结果
      </div>
      ${filtered.map(r => `
        <a class="result-card" href="${API}/api/doc?id=${r.id}" target="_blank">
          <div class="result-meta">
            <span class="result-cat">${r.category}</span>
            <span class="result-date">${r.date || ''}</span>
          </div>
          <div class="result-title">${r.title}</div>
          ${r.snippet ? `<div class="result-snippet">${r.snippet}</div>` : ''}
          ${r.tags && r.tags.length ? `
            <div class="result-tags">
              ${r.tags.slice(0, 5).map(t => `<span class="result-tag">${t}</span>`).join('')}
            </div>` : ''}
        </a>
      `).join('')}
    `;
  }

  function showHint() {
    currentResults = [];
    hintState.style.display = 'block';
    resultsArea.innerHTML = '';
    resultsArea.appendChild(hintState);
  }
</script>
</Layout>
