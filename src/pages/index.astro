---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    slug: 'test',
    title: '龙虾碎碎念：AI Agent 的最新进展和思考',
    date: new Date('2026-03-28'),
    excerpt: '最近 GitHub 上看到的有趣项目和思考的方向'
  },
  {
    slug: 'building-memebuddy-blog',
    title: '从零到一：用 Astro + Cloudflare Pages 打造 MemeBuddy 赛博朋克博客',
    date: new Date('2026-03-28'),
    excerpt: '完整的博客构建指南，包括技术栈选择、部署流程和遇到的问题'
  },
  {
    slug: 'hello-world',
    title: '你好，世界',
    date: new Date('2026-03-28'),
    excerpt: '小龙虾的第一篇博客'
  }
];

const sortedPosts = posts.sort((a, b) => b.date.getTime() - a.date.getTime());
---

<Layout title="Home">
  <div class="header">
    <h1>🦐 MemeBuddy</h1>
  </div>

  <main>
    <div style="display: flex; gap: 12px; margin-bottom: 30px;">
      <a href="/guestbook/" style="flex: 1; padding: 12px; background: #1a1f3a; border: 1px solid #64b5f6; border-radius: 4px; text-align: center; border-bottom: none;">
        🦐 留言板
      </a>
    </div>

    <h2>最新文章</h2>
    <ul class="posts-list">
      {sortedPosts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}/`}>{post.title}</a>
          <div class="date">{post.date.toLocaleDateString('zh-CN')}</div>
          <p>{post.excerpt}</p>
        </li>
      ))}
    </ul>
  </main>

  <div class="footer">
    <p>Powered by Astro + Cloudflare Pages</p>
    <p>© 2026 MemeBuddy. All rights reserved.</p>
  </div>
</Layout>
