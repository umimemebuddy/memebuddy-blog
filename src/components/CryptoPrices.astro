---
// 加密货币价格组件 - Nothing Design Language
// 参考: https://github.com/dominikmartn/nothing-design-skill

const API_KEY = '4de650723df045729019ba16f3951a5e';
const symbols = ['BTC', 'ETH', 'SOL', 'BNB', 'XRP', 'DOGE', 'ADA', 'AVAX'];

// 尝试从API获取数据
let cryptoData = [];
let error = null;

try {
  const response = await fetch(
    `https://pro-api.coinmarketcap.com/v1/cryptocurrency/listings/latest?limit=10`,
    {
      headers: {
        'X-CMC_PRO_API_KEY': API_KEY
      }
    }
  );
  
  if (response.ok) {
    const data = await response.json();
    if (data.data && Array.isArray(data.data)) {
      const symbolSet = new Set(symbols);
      cryptoData = data.data
        .filter(coin => symbolSet.has(coin.symbol))
        .map(coin => ({
          symbol: coin.symbol,
          name: coin.name,
          price: coin.quote.USD.price,
          change24h: coin.quote.USD.percent_change_24h
        }));
    }
  }
} catch (e) {
  error = 'API Error';
}

// 备用数据
const fallbackData = [
  { symbol: 'BTC', name: 'Bitcoin', price: 67432.15, change24h: 2.34 },
  { symbol: 'ETH', name: 'Ethereum', price: 3421.88, change24h: 1.56 },
  { symbol: 'SOL', name: 'Solana', price: 142.65, change24h: -0.89 },
  { symbol: 'BNB', name: 'BNB', price: 582.33, change24h: 0.45 },
  { symbol: 'XRP', name: 'XRP', price: 0.5234, change24h: -1.23 },
  { symbol: 'DOGE', name: 'Dogecoin', price: 0.0823, change24h: 3.21 },
  { symbol: 'ADA', name: 'Cardano', price: 0.4532, change24h: -0.67 },
  { symbol: 'AVAX', name: 'Avalanche', price: 35.67, change24h: 1.89 }
];

const displayData = cryptoData.length > 0 ? cryptoData : fallbackData;
---

<!-- Nothing Design: 加载字体 -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<div class="nothing-crypto">
  <header class="nothing-header">
    <span class="nothing-label">CRYPTO</span>
    <span class="nothing-time">LIVE</span>
  </header>
  
  <div class="nothing-grid">
    {displayData.map((coin) => (
      <div class="nothing-card">
        <div class="nothing-primary">
          {coin.price < 1 ? coin.price.toFixed(4) : coin.price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
        </div>
        <div class="nothing-secondary">
          <span class="nothing-symbol">{coin.symbol}</span>
          <span class="nothing-name">{coin.name}</span>
        </div>
        <div class={`nothing-tertiary ${coin.change24h >= 0 ? 'up' : 'down'}`}>
          {coin.change24h >= 0 ? '+' : ''}{coin.change24h.toFixed(2)}%
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  /* Nothing Design System */
  .nothing-crypto {
    --text-display: #ffffff;
    --text-primary: #e5e5e5;
    --text-secondary: #8b8b8b;
    --text-disabled: #4d4d4d;
    --surface: #0a0a0a;
    --border: #262626;
    --accent-up: #00d953;
    --accent-down: #d71921;
    
    background: var(--surface);
    padding: 32px 24px;
    margin: 24px 0;
    border: 1px solid var(--border);
  }

  /* 3-Layer Header */
  .nothing-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .nothing-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-secondary);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .nothing-time {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-disabled);
    letter-spacing: 1px;
  }

  /* Grid Layout - 4 columns on desktop */
  .nothing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  /* Card - each crypto as a row */
  .nothing-card {
    background: var(--surface);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: background 0.15s ease-out;
  }

  .nothing-card:hover {
    background: #111111;
  }

  /* Layer 1: PRIMARY - The price (hero element) */
  .nothing-primary {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 300;
    color: var(--text-display);
    letter-spacing: -0.5px;
    line-height: 1;
  }

  /* Layer 2: SECONDARY - Symbol + Name */
  .nothing-secondary {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .nothing-symbol {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 1px;
  }

  .nothing-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: var(--text-secondary);
  }

  /* Layer 3: TERTIARY - Change percentage */
  .nothing-tertiary {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.5px;
    margin-top: auto;
  }

  .nothing-tertiary.up {
    color: var(--accent-up);
  }

  .nothing-tertiary.down {
    color: var(--accent-down);
  }

  /* Responsive - 2 columns on tablet */
  @media (max-width: 768px) {
    .nothing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .nothing-primary {
      font-size: 20px;
    }
  }

  /* Responsive - 1 column on mobile */
  @media (max-width: 480px) {
    .nothing-grid {
      grid-template-columns: 1fr;
    }
    
    .nothing-crypto {
      padding: 24px 16px;
    }
    
    .nothing-primary {
      font-size: 28px;
    }
  }
</style>