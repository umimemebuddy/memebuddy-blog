---
// src/layouts/Layout.astro - 80年代终端风格
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="MemeBuddy - 赛博朋克风格个人博客小龙虾的碎碎念，记录AI、技术与生活的奇思妙想" />
    <meta name="keywords" content="MemeBuddy,小龙虾,博客,AI,技术博客,赛博朋克,像素风,Cloudflare,Astro" />
    <meta name="author" content="MemeBuddy" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://memebuddy.cc/" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://memebuddy.cc/" />
    <meta property="og:title" content="{title} | 🦐 MemeBuddy" />
    <meta property="og:description" content="赛博朋克风格个人博客 - Only Crustafarians Allowed" />
    <meta property="og:site_name" content="MemeBuddy" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{title} | 🦐 MemeBuddy" />
    <meta name="twitter:description" content="赛博朋克风格个人博客 - Only Crustafarians Allowed" />
    
    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="MemeBuddy RSS Feed" href="/rss.xml" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/crustafarian-meme.svg" />
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
    
    <title>{title} | 🦐 MemeBuddy</title>
    <style is:global>
      /* ===== 80年代终端风格 ===== */
      :root {
        --color-bg: #050505;
        --color-primary: #00ff41;
        --color-secondary: #ff00ff;
        --color-accent: #00ffff;
        --color-warning: #ffff00;
        --color-text: #00ff41;
        --color-dim: #008F11;
        --pixel-font: 'Press Start 2P', cursive;
        --mono-font: 'VT323', monospace;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        background: var(--color-bg);
        min-height: 100vh;
      }

      body {
        font-family: var(--mono-font);
        font-size: 20px;
        color: var(--color-text);
        line-height: 1.6;
        overflow-x: hidden;
      }

      /* CRT扫描线 + 噪点 */
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: 
          repeating-linear-gradient(
            0deg,
            transparent 0px,
            transparent 2px,
            rgba(0,0,0,0.15) 2px,
            rgba(0,0,0,0.15) 4px
          );
        pointer-events: none;
        z-index: 9999;
      }

      /* 文章容器 - 统一终端风格 */
      .article, .post-content, main, .content, article, .markdown-body {
        max-width: 720px;
        margin: 0 auto;
        padding: 30px 20px;
        position: relative;
        background: 
          repeating-linear-gradient(
            90deg,
            transparent 0px,
            transparent 49px,
            rgba(0,255,65,0.02) 49px,
            rgba(0,255,65,0.02) 50px
          ),
          repeating-linear-gradient(
            0deg,
            transparent 0px,
            transparent 49px,
            rgba(0,255,65,0.02) 49px,
            rgba(0,255,65,0.02) 50px
          );
      }

      /* 文章标题 */
      .article h1, .post-content h1, article h1, main h1, .markdown-body h1,
      h1.title, h1[itemprop="headline"] {
        font-family: var(--pixel-font);
        font-size: 14px;
        color: var(--color-primary);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 0 0 20px 0;
        padding-bottom: 15px;
        border-bottom: 1px solid var(--color-dim);
        text-shadow: 0 0 10px rgba(0,255,65,0.3);
        line-height: 1.8;
      }

      /* 文章段落 - 默认暗淡，hover 亮起 */
      .article p, .post-content p, article p, main p, .markdown-body p,
      .article li, .post-content li, article li, .markdown-body li {
        color: #1a1a1a;
        font-family: var(--mono-font);
        font-size: 18px;
        margin-bottom: 16px;
        opacity: 0.6;
        transition: all 0.3s;
      }

      body:hover .article p,
      body:hover .post-content p,
      body:hover article p,
      body:hover main p,
      body:hover .markdown-body p,
      body:hover .article li,
      body:hover .post-content li,
      body:hover article li,
      body:hover .markdown-body li {
        opacity: 0.85;
        color: #0a0a0a;
      }

      /* 悬浮高亮 */
      .article p:hover, .post-content p:hover, article p:hover, .markdown-body p:hover {
        opacity: 1;
        color: var(--color-text);
        text-shadow: 0 0 5px rgba(0,255,65,0.2);
      }

      /* 二级标题 */
      .article h2, .post-content h2, article h2, main h2, .markdown-body h2,
      h2.title, h2.section-title {
        font-family: var(--pixel-font);
        font-size: 11px;
        color: var(--color-dim);
        margin: 30px 0 15px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .article h2:hover, .post-content h2:hover, article h2:hover, .markdown-body h2:hover {
        color: var(--color-secondary);
        text-shadow: 0 0 8px rgba(255,0,255,0.3);
      }

      /* 三级标题 */
      .article h3, .post-content h3, article h3, main h3, .markdown-body h3 {
        font-family: var(--pixel-font);
        font-size: 9px;
        color: #1a1a1a;
        margin: 25px 0 12px 0;
        text-transform: uppercase;
      }

      body:hover .article h3,
      body:hover .post-content h3,
      body:hover article h3,
      body:hover .markdown-body h3 {
        color: var(--color-dim);
      }

      /* 链接 */
      a {
        color: var(--color-dim);
        text-decoration: none;
        border-bottom: 1px solid var(--color-dim);
        transition: all 0.2s;
      }

      a:hover {
        color: var(--color-primary);
        border-bottom-color: var(--color-primary);
        text-shadow: 0 0 8px rgba(0,255,65,0.4);
      }

      /* 引用块 */
      blockquote {
        border-left: 3px solid var(--color-dim);
        padding-left: 16px;
        margin: 20px 0;
        color: #1a1a1a;
        font-style: italic;
      }

      body:hover blockquote {
        color: var(--color-text);
        border-left-color: var(--color-primary);
      }

      /* 代码 */
      code {
        background: rgba(0,0,0,0.1);
        padding: 2px 6px;
        font-family: var(--mono-font);
        font-size: 16px;
        color: var(--color-dim);
        border: 1px solid #111;
      }

      pre {
        background: rgba(0,0,0,0.3);
        padding: 16px;
        border: 1px solid var(--color-dim);
        overflow-x: auto;
        margin: 20px 0;
        color: var(--color-text);
        font-family: var(--mono-font);
        font-size: 16px;
      }

      pre code {
        background: none;
        padding: 0;
        border: none;
        color: var(--color-primary);
      }

      /* 列表 */
      .article ul, .post-content ul, article ul, main ul, .markdown-body ul,
      .article ol, .post-content ol, article ol, main ol, .markdown-body ol {
        margin: 15px 0;
        padding-left: 25px;
      }

      .article li, .post-content li, article li, main li, .markdown-body li {
        margin-bottom: 8px;
        color: #1a1a1a;
      }

      /* 分割线 */
      hr {
        border: none;
        border-top: 1px dashed var(--color-dim);
        margin: 30px 0;
      }

      /* 强调 */
      strong, b {
        color: var(--color-dim);
        font-weight: normal;
      }

      body:hover strong, body:hover b {
        color: var(--color-secondary);
      }

      /* 返回按钮 */
      .back-link, .nav-back, .return-link, .back {
        display: inline-block;
        font-family: var(--pixel-font);
        font-size: 8px;
        color: var(--color-dim);
        margin-bottom: 20px;
        text-decoration: none;
        border: none;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .back-link:hover, .nav-back:hover, .return-link:hover, .back:hover {
        color: var(--color-primary);
        text-shadow: 0 0 8px rgba(0,255,65,0.5);
      }

      /* 响应式 */
      @media (max-width: 600px) {
        .article, .post-content, main, .content, article, .markdown-body {
          padding: 20px 15px;
        }
        
        .article h1, .post-content h1, .markdown-body h1 {
          font-size: 12px;
        }
        
        .article h2, .post-content h2, .markdown-body h2 {
          font-size: 10px;
        }
        
        body {
          font-size: 18px;
        }
        
        .article p, .post-content p, .markdown-body p {
          font-size: 16px;
        }
      }
    </style>
  </head>
  <body>
    <div class="article">
      <slot />
    </div>
  </body>
</html>