<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<Layout title="Home">
<style>
  :root {
    --bg: #050505;
    --bd: #151515;
    --tx: #d0d0d0;
    --tx2: #555;
    --tx3: #2a2a2a;
    --ac: #00ff41;
    --c1: #e0e0e0;
    --c2: #00ff41;
    --c3: #ffd700;
    --c4: #00b4d8;
    --c5: #ff6b6b;
  }
  .article, body::before { max-width: 100% !important; padding: 0 !important; background: var(--bg) !important; }
  body::before { display: none !important; }
  .a { max-width: 820px; margin: 0 auto; min-height: 100vh; border-left: 1px solid var(--bd); border-right: 1px solid var(--bd); }
  .b { display: flex; align-items: center; justify-content: space-between; padding: 10px 28px; border-bottom: 1px solid var(--bd); }
  .c { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx3); letter-spacing: 3px; }
  .d { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx3); }
  .e { padding: 36px 28px 28px; border-bottom: 1px solid var(--bd); }
  .f { font-family: 'Space Grotesk', sans-serif; font-size: 44px; font-weight: 300; color: var(--tx); letter-spacing: -1px; line-height: 1; margin-bottom: 10px; }
  .f em { font-style: normal; color: var(--ac); }
  .g { font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--tx2); line-height: 1.5; margin-bottom: 14px; }
  .h { display: flex; gap: 6px; flex-wrap: wrap; }
  .i { padding: 7px 12px; border: 1px solid var(--bd); font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx2); text-decoration: none; letter-spacing: 1px; transition: border-color .1s, color .1s; }
  .i:hover { border-color: var(--ac); color: var(--ac); }
  .j { display: flex; border-bottom: 1px solid var(--bd); }
  .k { flex: 1; padding: 12px 20px; border-right: 1px solid var(--bd); text-decoration: none; display: block; transition: background .1s; }
  .k:hover { background: #0a0a0a; }
  .k:last-child { border-right: none; }
  .l { font-family: 'Space Mono', monospace; font-size: 8px; color: var(--tx3); letter-spacing: 2px; margin-bottom: 3px; }
  .m { font-family: 'Space Grotesk', sans-serif; font-size: 14px; color: var(--tx2); }
  .m.ac { color: var(--ac); font-family: 'Space Mono', monospace; font-size: 11px; }
  .m.di { color: var(--tx3); font-family: 'Space Mono', monospace; font-size: 10px; }
  .n { border-bottom: 1px solid var(--bd); }
  .o { display: flex; }
  .p { flex: 1; font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; color: var(--tx3); background: transparent; border: none; border-right: 1px solid var(--bd); padding: 11px 12px; cursor: pointer; letter-spacing: 1px; transition: color .1s, background .1s; }
  .p:last-child { border-right: none; }
  .p:hover { color: var(--tx); background: #0a0a0a; }
  .p.on { color: var(--ac); background: rgba(0,255,65,.05); }
  .q { border-bottom: 1px solid var(--bd); }
  .r { display: grid; grid-template-columns: 68px 48px 1fr; border-bottom: 1px solid var(--bd); text-decoration: none; transition: background .1s; }
  .r:last-child { border-bottom: none; }
  .r:hover { background: #0a0a0a; }
  .s { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--tx3); display: flex; align-items: center; padding: 0 12px; border-right: 1px solid var(--bd); }
  .r:hover .s { color: var(--tx2); }
  .t { font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; display: flex; align-items: center; padding: 0 8px; border-right: 1px solid var(--bd); }
  .t.D, .r:hover .t.D { color: var(--tx3); }
  .t.B, .r:hover .t.B { color: var(--tx3); }
  .t.P, .r:hover .t.P { color: var(--tx3); }
  .t.T, .r:hover .t.T { color: var(--tx3); }
  .t.G, .r:hover .t.G { color: var(--tx3); }
  .r:hover .t.D { color: var(--c1); }
  .r:hover .t.B { color: var(--c2); }
  .r:hover .t.P { color: var(--c3); }
  .r:hover .t.T { color: var(--c4); }
  .r:hover .t.G { color: var(--c5); }
  .u { font-family: 'Space Grotesk', sans-serif; font-size: 13px; color: var(--tx2); display: flex; align-items: center; padding: 0 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color .1s; }
  .r:hover .u { color: var(--tx); }
  .v { display: flex; justify-content: space-between; align-items: center; padding: 10px 28px; border-top: 1px solid var(--bd); }
  .w { display: flex; gap: 16px; }
  .x { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx3); text-decoration: none; transition: color .1s; }
  .x:hover { color: var(--tx); }
  .x.di { opacity: .4; }
  .x.di:hover { opacity: 1; }
  .y { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--tx3); letter-spacing: 1px; }
  @media (max-width: 640px) {
    .a { border: none; }
    .e { padding: 24px 16px; }
    .f { font-size: 30px; }
    .b, .v { padding: 10px 16px; }
    .r { grid-template-columns: 56px 40px 1fr; }
  }
</style>

