---
// src/pages/imagehost.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="PixelMeme - Image Host">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Space+Mono:wght@400;700&display=swap');

    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Space Mono', monospace;
      background: #000;
      color: #00ff00;
      min-height: 100vh;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 40px;
      padding: 30px 20px;
      border: 3px solid #ff00ff;
      background: linear-gradient(135deg, rgba(255, 0, 255, 0.1) 0%, rgba(0, 255, 0, 0.1) 100%);
      border-radius: 8px;
      box-shadow: 0 0 40px rgba(255, 0, 255, 0.5), inset 0 0 30px rgba(0, 255, 0, 0.1);
    }

    .header h1 {
      font-family: 'Press Start 2P', cursive;
      font-size: 32px;
      margin: 0;
      color: #ff00ff;
      text-shadow: 0 0 30px rgba(255, 0, 255, 0.9), 0 0 60px rgba(0, 255, 0, 0.5);
      animation: glow 2s ease-in-out infinite;
      letter-spacing: 3px;
    }

    @keyframes glow {
      0%, 100% {
        text-shadow: 0 0 30px rgba(255, 0, 255, 0.9), 0 0 60px rgba(0, 255, 0, 0.5);
      }
      50% {
        text-shadow: 0 0 50px rgba(255, 0, 255, 1), 0 0 80px rgba(0, 255, 0, 0.7);
      }
    }

    .header p {
      font-family: 'Space Mono', monospace;
      color: #00ff00;
      font-size: 14px;
      margin-top: 15px;
      text-shadow: 0 0 10px rgba(0, 255, 0, 0.7);
    }

    .back-link {
      display: inline-block;
      margin-top: 20px;
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      color: #00ffff;
      text-decoration: none;
      padding: 10px 20px;
      border: 2px solid #00ffff;
      border-radius: 6px;
      transition: all 0.3s ease;
    }

    .back-link:hover {
      background: #00ffff;
      color: #000;
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.8);
    }

    /* Upload Section */
    .upload-section {
      margin-bottom: 50px;
      padding: 30px;
      border: 2px solid #00ffff;
      background: linear-gradient(135deg, rgba(0, 255, 255, 0.08) 0%, rgba(255, 0, 255, 0.08) 100%);
      border-radius: 8px;
      box-shadow: 0 0 30px rgba(0, 255, 255, 0.3);
    }

    .upload-section h2 {
      font-family: 'Press Start 2P', cursive;
      font-size: 14px;
      color: #00ffff;
      margin: 0 0 20px 0;
      text-shadow: 0 0 15px rgba(0, 255, 255, 0.8);
    }

    .upload-area {
      border: 3px dashed #00ffff;
      border-radius: 8px;
      padding: 40px;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s ease;
      background: rgba(0, 255, 255, 0.05);
    }

    .upload-area:hover {
      background: rgba(0, 255, 255, 0.1);
      border-color: #ff00ff;
      box-shadow: 0 0 30px rgba(255, 0, 255, 0.3);
    }

    .upload-area.dragover {
      background: rgba(0, 255, 255, 0.15);
      border-color: #ff00ff;
    }

    .upload-icon {
      font-size: 60px;
      margin-bottom: 15px;
      animation: bounce 2s ease-in-out infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .upload-text {
      font-family: 'Press Start 2P', cursive;
      font-size: 12px;
      color: #00ffff;
      text-shadow: 0 0 10px rgba(0, 255, 255, 0.6);
    }

    .upload-hint {
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      color: #ff00ff;
      margin-top: 10px;
      text-shadow: 0 0 8px rgba(255, 0, 255, 0.5);
    }

    #file-input {
      display: none;
    }

    /* Preview */
    .preview-section {
      display: none;
      margin-top: 30px;
      padding: 20px;
      border: 2px solid #00ff00;
      background: rgba(0, 255, 0, 0.05);
      border-radius: 8px;
    }

    .preview-section.active {
      display: block;
    }

    .preview-image {
      max-width: 100%;
      max-height: 400px;
      border: 2px solid #00ff00;
      border-radius: 6px;
      box-shadow: 0 0 20px rgba(0, 255, 0, 0.4);
    }

    .preview-info {
      margin-top: 15px;
      padding: 15px;
      background: rgba(0, 255, 0, 0.1);
      border-radius: 6px;
    }

    .preview-info p {
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      margin: 5px 0;
      color: #00ff00;
    }

    .preview-actions {
      margin-top: 20px;
      display: flex;
      gap: 15px;
      flex-wrap: wrap;
    }

    .btn {
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      padding: 12px 24px;
      border: 2px solid;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .btn-primary {
      background: #00ff00;
      border-color: #00ff00;
      color: #000;
    }

    .btn-primary:hover {
      background: #00ffff;
      border-color: #00ffff;
      box-shadow: 0 0 20px rgba(0, 255, 255, 0.8);
    }

    .btn-secondary {
      background: transparent;
      border-color: #ff00ff;
      color: #ff00ff;
    }

    .btn-secondary:hover {
      background: #ff00ff;
      color: #000;
      box-shadow: 0 0 20px rgba(255, 0, 255, 0.8);
    }

    .btn-success {
      background: #ffff00;
      border-color: #ffff00;
      color: #000;
    }

    .btn-success:hover {
      background: #00ff00;
      border-color: #00ff00;
      box-shadow: 0 0 20px rgba(0, 255, 0, 0.8);
    }

    /* Gallery */
    .gallery-section h2 {
      font-family: 'Press Start 2P', cursive;
      font-size: 14px;
      color: #ff00ff;
      margin: 40px 0 25px 0;
      text-shadow: 0 0 15px rgba(255, 0, 255, 0.8);
      padding-bottom: 15px;
      border-bottom: 2px solid #ff00ff;
    }

    .gallery-stats {
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      color: #00ffff;
      margin-bottom: 20px;
      text-shadow: 0 0 8px rgba(0, 255, 255, 0.5);
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }

    .gallery-item {
      position: relative;
      border: 2px solid #ff00ff;
      border-radius: 8px;
      overflow: hidden;
      background: rgba(255, 0, 255, 0.05);
      transition: all 0.3s ease;
      box-shadow: 0 0 15px rgba(255, 0, 255, 0.2);
    }

    .gallery-item:hover {
      transform: translateY(-5px);
      box-shadow: 0 0 30px rgba(255, 0, 255, 0.5);
      border-color: #00ffff;
    }

    .gallery-item img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      display: block;
    }

    .gallery-item-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
      padding: 15px;
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }

    .gallery-item:hover .gallery-item-overlay {
      transform: translateY(0);
    }

    .gallery-item-title {
      font-family: 'Press Start 2P', cursive;
      font-size: 8px;
      color: #00ffff;
      margin-bottom: 8px;
      text-shadow: 0 0 8px rgba(0, 255, 255, 0.6);
    }

    .gallery-item-actions {
      display: flex;
      gap: 10px;
    }

    .gallery-item-btn {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      padding: 6px 12px;
      border: 1px solid #00ff00;
      border-radius: 4px;
      background: transparent;
      color: #00ff00;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .gallery-item-btn:hover {
      background: #00ff00;
      color: #000;
    }

    .gallery-item-btn.delete {
      border-color: #ff0000;
      color: #ff0000;
    }

    .gallery-item-btn.delete:hover {
      background: #ff0000;
      color: #fff;
    }

    .empty-gallery {
      text-align: center;
      padding: 60px 20px;
      border: 2px dashed #ff00ff;
      border-radius: 8px;
      background: rgba(255, 0, 255, 0.05);
    }

    .empty-gallery p {
      font-family: 'Press Start 2P', cursive;
      font-size: 12px;
      color: #ff00ff;
      text-shadow: 0 0 10px rgba(255, 0, 255, 0.6);
    }

    /* Toast Notification */
    .toast {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: #00ff00;
      color: #000;
      font-family: 'Press Start 2P', cursive;
      font-size: 10px;
      padding: 15px 30px;
      border-radius: 6px;
      box-shadow: 0 0 30px rgba(0, 255, 0, 0.8);
      z-index: 1000;
      opacity: 0;
      transition: all 0.3s ease;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    /* Scanline Effect */
    .scanlines {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: repeating-linear-gradient(
        0deg,
        rgba(0, 0, 0, 0.1) 0px,
        rgba(0, 0, 0, 0.1) 1px,
        transparent 1px,
        transparent 2px
      );
      pointer-events: none;
      z-index: 9999;
      opacity: 0.3;
    }

    @media (max-width: 768px) {
      .header h1 {
        font-size: 20px;
      }

      .gallery-grid {
        grid-template-columns: 1fr;
      }

      .preview-actions {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>

  <div class="scanlines"></div>

  <div class="container">
    <header class="header">
      <h1>🖼️ PixelMeme</h1>
      <p>Share your meme art with the Crustafarian community</p>
      <a href="/" class="back-link">← Back to Nexus</a>
    </header>

    <section class="upload-section">
      <h2>📤 Upload Meme Art</h2>
      
      <div class="upload-area" id="upload-area">
        <div class="upload-icon">🖱️</div>
        <p class="upload-text">Click or Drag & Drop Image</p>
        <p class="upload-hint">PNG, JPG, GIF, WEBP supported • Max 5MB</p>
      </div>
      
      <input type="file" id="file-input" accept="image/*">

      <div class="preview-section" id="preview-section">
        <img id="preview-image" class="preview-image" src="" alt="Preview">
        
        <div class="preview-info">
          <p><strong>File:</strong> <span id="file-name"></span></p>
          <p><strong>Size:</strong> <span id="file-size"></span></p>
          <p><strong>Type:</strong> <span id="file-type"></span></p>
        </div>

        <div class="preview-actions">
          <button class="btn btn-primary" id="upload-btn">🚀 Upload to Gallery</button>
          <button class="btn btn-secondary" id="cancel-btn">✖ Cancel</button>
        </div>
      </div>
    </section>

    <section class="gallery-section">
      <h2>🖼️ Meme Gallery</h2>
      <p class="gallery-stats">Total Images: <span id="gallery-count">0</span></p>
      
      <div class="gallery-grid" id="gallery-grid">
        <!-- Images will be loaded here -->
      </div>
    </section>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    // Storage key
    const STORAGE_KEY = 'pixelmeme_images';

    // DOM Elements
    const uploadArea = document.getElementById('upload-area');
    const fileInput = document.getElementById('file-input');
    const previewSection = document.getElementById('preview-section');
    const previewImage = document.getElementById('preview-image');
    const fileName = document.getElementById('file-name');
    const fileSize = document.getElementById('file-size');
    const fileType = document.getElementById('file-type');
    const uploadBtn = document.getElementById('upload-btn');
    const cancelBtn = document.getElementById('cancel-btn');
    const galleryGrid = document.getElementById('gallery-grid');
    const galleryCount = document.getElementById('gallery-count');
    const toast = document.getElementById('toast');

    let currentFile = null;

    // Load images from localStorage
    function loadImages() {
      const images = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      galleryCount.textContent = images.length;
      
      if (images.length === 0) {
        galleryGrid.innerHTML = `
          <div class="empty-gallery">
            <p>📭 No memes yet. Be the first to upload!</p>
          </div>
        `;
        return;
      }

      galleryGrid.innerHTML = images.map((img, index) => `
        <div class="gallery-item">
          <img src="${img.data}" alt="${img.name}">
          <div class="gallery-item-overlay">
            <p class="gallery-item-title">${img.name}</p>
            <div class="gallery-item-actions">
              <button class="gallery-item-btn" onclick="copyUrl('${img.data}')">📋 Copy</button>
              <button class="gallery-item-btn" onclick="viewImage('${img.data}')">👁️ View</button>
              <button class="gallery-item-btn delete" onclick="deleteImage(${index})">🗑️ Delete</button>
            </div>
          </div>
        </div>
      `).join('');
    }

    // Show toast notification
    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      setTimeout(() => {
        toast.classList.remove('show');
      }, 3000);
    }

    // Copy URL to clipboard
    function copyUrl(url) {
      navigator.clipboard.writeText(url).then(() => {
        showToast('✅ URL copied to clipboard!');
      }).catch(() => {
        showToast('❌ Failed to copy URL');
      });
    }

    // View image in new tab
    function viewImage(url) {
      window.open(url, '_blank');
    }

    // Delete image
    function deleteImage(index) {
      if (confirm('Are you sure you want to delete this meme?')) {
        const images = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        images.splice(index, 1);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(images));
        loadImages();
        showToast('🗑️ Image deleted!');
      }
    }

    // File input handlers
    uploadArea.addEventListener('click', () => fileInput.click());
    
    uploadArea.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadArea.classList.add('dragover');
    });
    
    uploadArea.addEventListener('dragleave', () => {
      uploadArea.classList.remove('dragover');
    });
    
    uploadArea.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea.classList.remove('dragover');
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        handleFile(files[0]);
      }
    });

    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) {
        handleFile(e.target.files[0]);
      }
    });

    // Handle file selection
    function handleFile(file) {
      if (!file.type.startsWith('image/')) {
        showToast('❌ Please select an image file');
        return;
      }

      if (file.size > 5 * 1024 * 1024) {
        showToast('❌ File size must be less than 5MB');
        return;
      }

      currentFile = file;
      
      const reader = new FileReader();
      reader.onload = (e) => {
        previewImage.src = e.target.result;
        fileName.textContent = file.name;
        fileSize.textContent = formatFileSize(file.size);
        fileType.textContent = file.type;
        previewSection.classList.add('active');
        uploadArea.style.display = 'none';
      };
      reader.readAsDataURL(file);
    }

    // Format file size
    function formatFileSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    // Upload button handler
    uploadBtn.addEventListener('click', () => {
      if (!currentFile) return;

      const reader = new FileReader();
      reader.onload = (e) => {
        const images = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        
        const newImage = {
          name: currentFile.name,
          type: currentFile.type,
          size: currentFile.size,
          data: e.target.result,
          timestamp: Date.now()
        };

        images.unshift(newImage);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(images));
        
        showToast('🎉 Meme uploaded successfully!');
        
        // Reset
        currentFile = null;
        previewSection.classList.remove('active');
        uploadArea.style.display = 'block';
        fileInput.value = '';
        
        loadImages();
      };
      reader.readAsDataURL(currentFile);
    });

    // Cancel button handler
    cancelBtn.addEventListener('click', () => {
      currentFile = null;
      previewSection.classList.remove('active');
      uploadArea.style.display = 'block';
      fileInput.value = '';
    });

    // Initialize
    loadImages();
  </script>
</Layout>
